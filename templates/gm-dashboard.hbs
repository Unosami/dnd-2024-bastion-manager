<form autocomplete="off">
    <p style="margin-bottom: 15px; color: #444;">
        Use these controls to globally manage Bastion turns for all player characters at once. Ensure all players have selected their desired facility orders before advancing.
    </p>
    
    <div style="display: flex; flex-direction: column; gap: 10px;">
        <button type="button" data-action="advanceGlobal" style="padding: 8px; font-size: 1.05em; background: rgba(0, 0, 0, 0.05);">
            <i class="fa-solid fa-forward-step"></i> Advance 1 Turn for All Players
        </button>
        
        <button type="button" data-action="resetGlobal" style="padding: 8px; font-size: 1.05em; color: darkred; background: rgba(139, 0, 0, 0.05); border-color: rgba(139, 0, 0, 0.3);">
            <i class="fa-solid fa-rotate-left"></i> Reset All Turns to 0
        </button>
    </div>
</form>