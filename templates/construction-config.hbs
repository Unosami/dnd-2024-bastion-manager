<div class="construction-config-container" style="padding: 10px; max-height: 85vh; overflow-y: auto;">
    <p class="notes" style="margin-bottom: 8px; font-style: italic; color: #777; font-size: 0.85em;">Adjust scaling for gold and time requirements. Changes apply after saving.</p>

    <section class="info-panel" style="background: rgba(0,0,0,0.2); border: 1px solid #444; border-radius: 4px; padding: 8px; margin-bottom: 15px;">
        <h3 style="margin: 0 0 8px 0; font-size: 1.05em; border-bottom: 2px solid #a32a22; display: flex; align-items: center; gap: 8px;">
            <i class="fas fa-calculator"></i> Current Cost Estimates
        </h3>
        
        <div style="font-weight: bold; font-size: 0.8em; color: #bbb; text-transform: uppercase; margin-bottom: 4px;">Construction (New)</div>
        <table style="width: 100%; border-collapse: collapse; font-size: 0.85em; margin-bottom: 10px;">
            <thead>
                <tr style="border-bottom: 1px solid #ddd; text-align: left;">
                    <th>Type</th>
                    <th style="text-align: right;">Gold</th>
                    <th style="text-align: right;">Turns (Days)</th>
                </tr>
            </thead>
            <tbody>
                {{#each previewAdd}}
                <tr style="border-bottom: 1px dashed #eee;">
                    <td style="padding: 2px 0;">{{this.label}}</td>
                    <td style="text-align: right; font-weight: bold; color: darkgoldenrod;" data-preview="{{this.key}}-gp">{{this.gp}} GP</td>
                    <td style="text-align: right;" data-preview="{{this.key}}-time">{{this.turns}} <span style="font-size: 0.9em; color: #888;">({{this.days}}d)</span></td>
                </tr>
                {{/each}}
            </tbody>
        </table>

        <div style="font-weight: bold; font-size: 0.8em; color: #bbb; text-transform: uppercase; margin-bottom: 4px;">Enlarging (Existing)</div>
        <table style="width: 100%; border-collapse: collapse; font-size: 0.85em;">
            <tbody>
                {{#each previewEnlarge}}
                <tr style="border-bottom: 1px dashed #eee;">
                    <td style="padding: 2px 0;">{{this.label}}</td>
                    <td style="text-align: right; font-weight: bold; color: darkgoldenrod;" data-preview="{{this.key}}-gp">{{this.gp}} GP</td>
                    <td style="text-align: right;" data-preview="{{this.key}}-time">{{this.turns}} <span style="font-size: 0.9em; color: #888;">({{this.days}}d)</span></td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </section>

    <div class="global-sliders" style="margin-bottom: 15px;">
        <div class="form-group" style="margin-bottom: 4px;">
            <label style="font-weight: bold; color: #a32a22; font-size: 0.9em;">Global Cost Multiplier</label>
            <div class="form-fields" style="display: flex; align-items: center; gap: 5px;">
                <input type="range" name="globalCost" value="{{globalCost}}" min="0" max="500" step="5" style="flex: 1;">
                <input type="number" name="globalCost_num" value="{{globalCost}}" min="0" max="500" step="1" style="width: 55px; height: 24px; text-align: center;">
                <span style="font-weight: bold; font-size: 0.85em; width: 15px;">%</span>
            </div>
        </div>

        <div class="form-group" style="margin-bottom: 4px;">
            <label style="font-weight: bold; color: #a32a22; font-size: 0.9em;">Global Time Multiplier</label>
            <div class="form-fields" style="display: flex; align-items: center; gap: 5px;">
                <input type="range" name="globalTime" value="{{globalTime}}" min="0" max="500" step="5" style="flex: 1;">
                <input type="number" name="globalTime_num" value="{{globalTime}}" min="0" max="500" step="1" style="width: 55px; height: 24px; text-align: center;">
                <span style="font-weight: bold; font-size: 0.85em; width: 15px;">%</span>
            </div>
        </div>
    </div>

    <details style="border: 1px solid #444; border-radius: 4px; padding: 0; overflow: hidden; margin-top: 10px;">
        <summary style="cursor: pointer; padding: 8px; font-weight: bold; background: #333; color: #fff; border-bottom: 1px solid #444;">
            <i class="fas fa-cog"></i> Advanced Granular Configuration
        </summary>
        
        <div style="padding: 8px; background: rgba(0,0,0,0.15);">
            <h4 style="border-bottom: 1px solid #666; font-size: 0.9em; margin-top: 0;"><i class="fas fa-hammer"></i> Base Construction Costs</h4>
            {{#each buildStages}}
            <div style="background: rgba(0,0,0,0.1); padding: 6px; border-radius: 4px; margin-bottom: 5px;">
                <label style="font-size: 0.9em; font-weight: bold;">
                    {{#if (eq this "buildCramped")}}Cramped Stage{{/if}}
                    {{#if (eq this "buildRoomy")}}Roomy Stage{{/if}}
                    {{#if (eq this "buildVast")}}Vast Stage{{/if}}
                </label>
                <div class="form-group" style="display: flex; align-items: center; gap: 8px; margin: 2px 0;">
                    <label style="flex: 0 0 70px; font-size: 0.75em; margin: 0;">Cost (GP)</label>
                    <div class="form-fields" style="display: flex; align-items: center; gap: 5px;">
                        <input type="range" name="{{this}}Cost" value="{{lookup ../this (concat this "Cost")}}" min="0" max="5000" step="50">
                        <input type="number" name="{{this}}Cost_num" value="{{lookup ../this (concat this "Cost")}}" min="0" max="5000" step="10" style="width: 60px; height: 22px; font-size: 0.8em;">
                    </div>
                </div>
                <div class="form-group" style="display: flex; align-items: center; gap: 8px; margin: 2px 0;">
                    <label style="flex: 0 0 70px; font-size: 0.75em; margin: 0;">Time (Turns)</label>
                    <div class="form-fields" style="display: flex; align-items: center; gap: 5px;">
                        <input type="range" name="{{this}}Time" value="{{lookup ../this (concat this "Time")}}" min="0" max="50" step="1">
                        <input type="number" name="{{this}}Time_num" value="{{lookup ../this (concat this "Time")}}" min="0" max="50" step="1" style="width: 60px; height: 22px; font-size: 0.8em;">
                    </div>
                </div>
            </div>
            {{/each}}

            <h4 style="border-bottom: 1px solid #666; margin-top: 10px; font-size: 0.9em;"><i class="fas fa-arrow-up-right-dots"></i> Base Enlargement Costs</h4>
            {{#each enlargeStages}}
            <div style="background: rgba(0,0,0,0.1); padding: 6px; border-radius: 4px; margin-bottom: 5px;">
                <label style="font-size: 0.9em; font-weight: bold;">
                    {{#if (eq this "enlargeRoomy")}}Cramped to Roomy{{/if}}
                    {{#if (eq this "enlargeVast")}}Roomy to Vast{{/if}}
                </label>
                <div class="form-group" style="display: flex; align-items: center; gap: 8px; margin: 2px 0;">
                    <label style="flex: 0 0 70px; font-size: 0.75em; margin: 0;">Cost (GP)</label>
                    <div class="form-fields" style="display: flex; align-items: center; gap: 5px;">
                        <input type="range" name="{{this}}Cost" value="{{lookup ../this (concat this "Cost")}}" min="0" max="5000" step="50">
                        <input type="number" name="{{this}}Cost_num" value="{{lookup ../this (concat this "Cost")}}" min="0" max="5000" step="10" style="width: 60px; height: 22px; font-size: 0.8em;">
                    </div>
                </div>
                <div class="form-group" style="display: flex; align-items: center; gap: 8px; margin: 2px 0;">
                    <label style="flex: 0 0 70px; font-size: 0.75em; margin: 0;">Time (Turns)</label>
                    <div class="form-fields" style="display: flex; align-items: center; gap: 5px;">
                        <input type="range" name="{{this}}Time" value="{{lookup ../this (concat this "Time")}}" min="0" max="50" step="1">
                        <input type="number" name="{{this}}Time_num" value="{{lookup ../this (concat this "Time")}}" min="0" max="50" step="1" style="width: 60px; height: 22px; font-size: 0.8em;">
                    </div>
                </div>
            </div>
            {{/each}}
        </div>
    </details>

    <footer class="sheet-footer" style="margin-top: 20px; display: flex; justify-content: center; border-top: 1px solid #ccc; padding-top: 10px;">
        <button type="submit" name="submit" style="width: auto; padding: 6px 20px; font-weight: bold; cursor: pointer;">
            <i class="fas fa-save"></i> Save Configuration
        </button>
    </footer>
</div>