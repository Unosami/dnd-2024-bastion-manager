<div class="bastion-manager-container" style="display: flex; gap: 15px; height: 100%; overflow: hidden;">
    
    <div class="bastion-sidebar" style="flex: 0 0 350px; overflow-y: auto; padding-right: 10px; border-right: 1px solid #ccc; display: flex; flex-direction: column;">
    <div class="sidebar-content-column">
    <div class="bastion-header" style="text-align: center; margin-bottom: 5px;">
        <h2 style="margin-bottom: 5px; line-height: 1.2;">{{actor.name}}'s Bastion</h2>
        <div style="font-size: 1em; display: flex; align-items: center; justify-content: center; gap: 15px; flex-wrap: wrap;">
            <span><b>Total Turns:</b> {{turnCount}}</span>
            <span><b>Total Defenders:</b> {{totalDefenders}}</span>

            {{#if neglectWarning}}
                <span class="neglect-warning" style="color: {{neglectColor}}; font-weight: bold; display: flex; align-items: center; gap: 4px;" 
                    title="Neglect Counter: {{neglectCounter}} / {{actorLevel}} turns. If this reaches {{actorLevel}} without an order being issued, the Bastion is lost.">
                    <i class="fa-solid fa-triangle-exclamation"></i> 
                    Decaying ({{neglectCounter}}/{{actorLevel}})
                    <i class="fa-solid fa-circle-info" style="font-size: 0.8em; opacity: 0.7;" title="NEGLECT RULES: If no orders are issued for a number of consecutive turns equal to your level, the Bastion is abandoned and looted. Issuing any order other than 'Maintain' resets this counter."></i>
                </span>
            {{/if}}

            {{#if (ne actor.type "group")}}
                <button type="button" data-action="toggleCombine" style="width: auto; padding: 2px 8px; font-size: 0.75em; {{#if combinedGroup}}color: green; font-weight: bold;{{/if}}" 
                    title="{{#if combinedGroup}}Combined with {{combinedGroup.name}}{{else}}Combine this Bastion with a shared Group Bastion{{/if}}">
                    <i class="fa-solid fa-people-group"></i> {{#if combinedGroup}}Combined{{else}}Combine{{/if}}
                </button>
            {{/if}}
            
            <button type="button" data-action="abandonBastion" style="width: auto; padding: 2px 8px; font-size: 0.75em; color: #a32a22;" 
                title="Abandon/Divest Bastion (Permanently removes all facilities)">
                <i class="fa-solid fa-burst"></i> Abandon
            </button>

            <div style="display: flex; gap: 5px; align-items: center; border: 1px solid #ccc; padding: 4px; border-radius: 4px; background: rgba(0,0,0,0.05);">
                <button type="button" data-action="maintainAll" style="width: auto; padding: 2px 8px; font-size: 0.75em;" title="Set all facilities to Maintain">
                    <i class="fa-solid fa-broom"></i> Maintain All
                </button>
            
                {{#if canAdvanceTurn}}
                    <span style="border-left: 1px solid #ccc; height: 20px; margin: 0 5px;"></span>
                    <input type="number" name="turns" value="1" min="1" style="width: 35px; text-align: center; height: 20px; font-size: 0.8em;" title="Turns to advance">
                    <button type="button" data-action="advanceGlobalTurn" style="width: auto; padding: 2px 8px; font-size: 0.75em; color: darkred;" title="Advance turns globally for all Bastions">
                        <i class="fa-solid fa-earth-americas"></i> Advance Turn
                    </button>
            {{/if}}
            </div>
        </div>
        
        {{#if defenderNames}}
            <div style="font-size: 0.85em; color: #444; margin-top: 5px; font-style: italic;">
                Known Defenders: {{defenderNames}}
            </div>
        {{/if}}
    </div>

    <hr style="margin: 5px 0;">

    {{#if isNewBastion}}
        <div class="bastion-welcome-splash" style="padding: 12px; text-align: center; background: rgba(128,0,128,0.05); border: 2px dashed purple; border-radius: 8px; margin: 10px 0;">
            <i class="fa-solid fa-chess-rook" style="font-size: 2.5em; color: purple; margin-bottom: 8px; opacity: 0.8;"></i>
            <h3 style="border: none; margin-bottom: 4px; font-size: 1.2em;">Found Your Bastion</h3>
            <p style="font-size: 0.85em; color: #444; margin-bottom: 12px;">Welcome to level 5! You may established your first four facilities <b>instantly and for free</b>.</p>
            <div style="display: flex; justify-content: center;">
                <button type="button" data-action="initializeBastion" style="width: auto; padding: 8px 20px; font-weight: bold; background: purple; color: white; cursor: pointer; border: none; border-radius: 4px;">
                    <i class="fa-solid fa-sparkles"></i> Quick-Start Founding
                </button>
            </div>
        </div>
    {{/if}}

    {{#if (ne actor.type "group")}}<div class="bastion-build-section" style="margin-bottom: 8px; display: flex; gap: 5px;">
        <select name="compendium-facility" style="flex-grow: 1;">
            <option value="">-- Select Facility to Build --</option>
            {{#each specialFacilities}}
                <optgroup label="Level {{this.level}}">
                {{#each this.facilities}}
                    <option value="{{this._id}}">
                        {{this.name}}{{#if this.prerequisite}}&nbsp;&nbsp; — &nbsp;&nbsp;{{this.prerequisite}}{{/if}}
                    </option>
                {{/each}}
                </optgroup>
            {{/each}}
            {{#if basicFacilities.length}}
                <optgroup label="Basic Facilities">
                {{#each basicFacilities}}
                    <option value="{{this._id}}">
                        {{this.name}}
                    </option>
                {{/each}}
                </optgroup>
            {{/if}}
        </select>
        <button type="button" data-action="buildFromDropdown" style="width: auto; padding: 4px 10px;">
            <i class="fa-solid fa-hammer"></i> Build
        </button>
    </div>{{/if}}

    {{#if combinedGroup}}
        <div style="background: rgba(0, 100, 200, 0.05); border: 1px solid #005a9e; padding: 6px; border-radius: 4px; margin-bottom: 10px; font-size: 0.85em; text-align: center; color: #004578;">
            <i class="fa-solid fa-link"></i> Linked to <b>{{combinedGroup.name}}</b>
        </div>
    {{/if}}

    <details data-section="special" {{#if sectionStates.special}}open{{/if}}>
        <summary style="cursor: pointer; border-bottom: 1px solid #ccc; margin-bottom: 5px;" title="Click to toggle section">
            <h3 style="display: inline; font-size: 1.1em;">Special Facilities ({{specialFacilitiesBuilt.length}})</h3>
        </summary>
    <ul style="list-style: none; padding: 0; margin: 0;">
        {{#each specialFacilitiesBuilt}}
            <li class="facility-item {{#if this.isLayoutActive}}active-layout{{/if}}" style="margin-bottom: 4px; padding: 3px; background: {{#if this.isLayoutActive}}rgba(0,0,0,0.12){{else}}rgba(0,0,0,0.02){{/if}}; border-radius: 3px; border-left: 4px solid {{this.facColor}}; {{#if this.isUnderConstruction}}opacity: 0.7;{{/if}}; display: flex; flex-direction: column; gap: 5px;">
                <div style="display: flex; align-items: flex-start; justify-content: space-between; width: 100%;">
                <div style="display: flex; gap: 6px; flex: 1;">
                <img src="{{this.img}}" width="24" height="24" style="border: none; border-radius: 3px; vertical-align: middle; {{#if this.isUnderConstruction}}filter: grayscale(1);{{/if}}">
                
                    <div style="flex: 1;">
                    <b style="font-size: 0.95em;">{{this.name}}</b> 
                    
                    <span style="font-size: 0.7em; background: {{#if (eq this.size "Construction")}}#a32a22; color: white;{{else}}#ddd; color: #333;{{/if}} padding: 1px 4px; border-radius: 3px; margin-left: 4px; vertical-align: middle;">{{this.size}}</span>
                    {{#if this.subType}}
                        <span style="font-size: 0.8em; color: darkgreen; margin-left: 5px; font-weight: bold;">[{{this.subType}}]</span>
                    {{/if}}

                    {{#if this.defenderCount}}
                        <span style="background: #a32a22; color: white; padding: 2px 6px; border-radius: 12px; font-size: 0.75em; margin-left: 5px;" title="Defenders housed here">
                            <i class="fa-solid fa-shield"></i> {{this.defenderCount}}
                        </span>
                    {{/if}}

                    {{#if this.hirelings}}
                        <span style="font-size: 0.85em; color: #555; font-style: italic; display: block;">(Hirelings: {{this.hirelings}})</span>
                    {{/if}}

                    <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-top: 1px;">
                        <div style="font-size: 0.65em; color: #666;">
                            <i class="fa-solid fa-layer-group"></i> Layout: 
                            <span style="{{#if (eq this.placedSquares this.maxSquares)}}color: green; font-weight: bold;{{/if}}">
                                {{this.placedSquares}} / {{this.maxSquares}} sq
                            </span>
                        </div>
                        {{#if this.isStorehouse}}
                            <div style="font-size: 0.65em; color: #555; text-align: right;" title="Current Stock / Maximum Capacity">
                                <i class="fa-solid fa-boxes-stacked"></i> <b>{{this.storedGp}} / {{this.storehouseLimit}} GP</b> (+{{this.storehouseMarkup}}%)
                            </div>
                        {{/if}}
                    </div>

                    {{#if this.hasOrders}}
                        <div style="font-size: 0.85em; margin-top: 2px; display: flex; align-items: center; gap: 4px; flex-wrap: wrap;">
                            {{#if this.showOrderDropdown}}
                                <label>Order: </label>
                                <select class="facility-order-select" 
                                        data-item-id="{{this.id}}" data-item-name="{{this.itemName}}" data-is-flag="{{this.isFlag}}" data-is-inherited="{{this.isInherited}}" data-member-id="{{this.memberId}}"
                                        {{#if this.isOrderLocked}}disabled style="opacity: 0.6; cursor: not-allowed;" title="This order is currently in progress and cannot be changed."{{/if}}>
                                    {{#each this.orderOptions}}
                                        <option value="{{this.value}}" {{#if this.selected}}selected{{/if}} style="font-size: 0.9em;">{{this.label}}</option>
                                    {{/each}}
                                </select>
                                {{#if this.isLibraryResearching}}
                                    <input type="text" class="library-topic-input" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}" data-is-inherited="{{this.isInherited}}" data-member-id="{{this.memberId}}" value="{{this.libraryTopic}}" placeholder="Enter topic..." style="height: 20px; font-size: 0.85em; width: 120px;">
                                {{/if}}
                                {{#if this.isArcaneStudyCrafting}}
                                    <div style="display: flex; flex-direction: column; gap: 4px; margin-top: 2px;">
                                        <select class="arcane-study-craft-select" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}" data-is-inherited="{{this.isInherited}}" data-member-id="{{this.memberId}}" style="height: 20px; font-size: 0.85em;" {{#if this.isOrderLocked}}disabled{{/if}}>
                                            <option value="">-- Select Craft --</option>
                                            {{#each craftOptions}}
                                                <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                                            {{/each}}
                                        </select>
                                        {{#if this.showArcanaItemSelect}}
                                            <div style="display: flex; align-items: center; gap: 4px;">
                                                <select class="arcane-study-item-select" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}" data-is-inherited="{{this.isInherited}}" data-member-id="{{this.memberId}}" style="height: 20px; font-size: 0.85em; flex: 1;" {{#if this.isOrderLocked}}disabled{{/if}}>
                                                    <option value="">-- Select Magic Item --</option>
                                                    {{#each magicItemOptions}}
                                                        {{#if this.groupOptions}}
                                                            <optgroup label="{{this.label}}">
                                                                {{#each this.groupOptions}}
                                                                    <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                                                                {{/each}}
                                                            </optgroup>
                                                        {{else}}
                                                            <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                                                        {{/if}}
                                                    {{/each}}
                                                </select>
                                                {{#if this.magicItemUuid}}
                                                    <a class="content-link" data-action="previewItem" data-uuid="{{this.magicItemUuid}}" draggable="true" style="font-size: 0.9em; height: 20px; display: flex; align-items: center; border: none; background: none;" title="View Item Details">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                {{/if}}
                                            </div>
                                        {{/if}}
                                        {{#if this.showArcaneFocusSelect}}
                                            <div style="display: flex; align-items: center; gap: 4px;">
                                            <select class="arcane-study-focus-select" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}" data-is-inherited="{{this.isInherited}}" data-member-id="{{this.memberId}}" style="height: 20px; font-size: 0.85em; flex: 1;" {{#if this.isOrderLocked}}disabled{{/if}}>
                                                <option value="">-- Select Focus Type --</option>
                                                {{#each focusOptions}}
                                                    {{#if this.groupOptions}}
                                                        <optgroup label="{{this.label}}">
                                                            {{#each this.groupOptions}}
                                                                <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                                                            {{/each}}
                                                        </optgroup>
                                                    {{else}}
                                                        <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                                                    {{/if}}
                                                {{/each}}
                                            </select>
                                            </div>
                                        {{/if}}
                                        {{#if (and this.craftChoice (not this.isInherited))}}
                                            <button type="button" data-action="addToQueue" data-item-id="{{this.id}}" style="height: 20px; font-size: 0.75em; margin-top: 2px;">
                                                <i class="fa-solid fa-plus"></i> Add to Craft Queue
                                            </button>
                                        {{/if}}
                                    </div>
                                {{/if}}
                                {{#if this.isSanctuaryCrafting}}
                                    <div style="display: flex; flex-direction: column; gap: 4px; margin-top: 2px;">
                                        <select class="sanctuary-craft-select" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}" data-is-inherited="{{this.isInherited}}" data-member-id="{{this.memberId}}" style="height: 20px; font-size: 0.85em;" {{#if this.isOrderLocked}}disabled{{/if}}>
                                            <option value="">-- Select Craft --</option>
                                            {{#each sanctuaryCraftOptions}}
                                                <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                                            {{/each}}
                                        </select>
                                        {{#if this.showSacredFocusSelect}}
                                            <div style="display: flex; align-items: center; gap: 4px;">
                                                <select class="sanctuary-focus-select" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}" data-is-inherited="{{this.isInherited}}" data-member-id="{{this.memberId}}" style="height: 20px; font-size: 0.85em; flex: 1;" {{#if this.isOrderLocked}}disabled{{/if}}>
                                                    <option value="">-- Select Focus Type --</option>
                                                    {{#each sacredFocusOptions}}
                                                        <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                                                    {{/each}}
                                                </select>
                                                {{#if this.sacredFocusUuid}}
                                                    <a class="content-link" data-action="previewItem" data-uuid="{{this.sacredFocusUuid}}" draggable="true" style="font-size: 0.9em; height: 20px; display: flex; align-items: center; border: none; background: none;" title="View Item Details">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                {{/if}}
                                            </div>
                                        {{/if}}
                                    </div>
                                {{/if}}
                                {{#if this.isSmithyCrafting}}
                                    <div style="display: flex; flex-direction: column; gap: 4px; margin-top: 2px;">
                                        <select class="smithy-craft-select" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}" data-is-inherited="{{this.isInherited}}" data-member-id="{{this.memberId}}" style="height: 20px; font-size: 0.85em;" {{#if this.isOrderLocked}}disabled{{/if}}>
                                            <option value="">-- Select Craft --</option>
                                            {{#each craftOptions}}
                                                <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                                            {{/each}}
                                        </select>
                                        {{#if this.showSmithyItemSelect}}
                                            <div style="display: flex; align-items: center; gap: 4px;">
                                                <select class="smithy-item-select" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}" data-is-inherited="{{this.isInherited}}" data-member-id="{{this.memberId}}" style="height: 20px; font-size: 0.85em; flex: 1;" {{#if this.isOrderLocked}}disabled{{/if}}>
                                                    <option value="">-- Select Item --</option>
                                                    {{#each smithyItemOptions}}
                                                        {{#if this.groupOptions}}
                                                            <optgroup label="{{this.label}}">
                                                                {{#each this.groupOptions}}
                                                                    <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                                                                {{/each}}
                                                            </optgroup>
                                                        {{else}}
                                                            <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                                                        {{/if}}
                                                    {{/each}}
                                                </select>
                                                {{#if this.smithyItemUuid}}
                                                    <a class="content-link" data-action="previewItem" data-uuid="{{this.smithyItemUuid}}" draggable="true" style="font-size: 0.9em; height: 20px; display: flex; align-items: center; border: none; background: none;" title="View Item Details">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                {{/if}}
                                            </div>
                                        {{/if}}
                                        {{#if this.showArmamentItemSelect}}
                                            <div style="display: flex; align-items: center; gap: 4px;">
                                                <select class="armament-item-select" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}" data-is-inherited="{{this.isInherited}}" data-member-id="{{this.memberId}}" style="height: 20px; font-size: 0.85em; flex: 1;" {{#if this.isOrderLocked}}disabled{{/if}}>
                                                    <option value="">-- Select Magic Item --</option>
                                                    {{#each armamentItemOptions}}
                                                        {{#if this.groupOptions}}
                                                            <optgroup label="{{this.label}}">
                                                                {{#each this.groupOptions}}
                                                                    <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                                                                {{/each}}
                                                            </optgroup>
                                                        {{else}}
                                                            <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                                                        {{/if}}
                                                    {{/each}}
                                                </select>
                                                {{#if this.armamentItemUuid}}
                                                    <a class="content-link" data-action="previewItem" data-uuid="{{this.armamentItemUuid}}" draggable="true" style="font-size: 0.9em; height: 20px; display: flex; align-items: center; border: none; background: none;" title="View Item Details">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                {{/if}}
                                            </div>
                                        {{/if}}
                                        {{#if (and this.craftChoice (not this.isInherited))}}
                                            <button type="button" data-action="addToQueue" data-item-id="{{this.id}}" style="height: 20px; font-size: 0.75em; margin-top: 2px;">
                                                <i class="fa-solid fa-plus"></i> Add to Craft Queue
                                            </button>
                                        {{/if}}
                                    </div>
                                {{/if}}

                                {{#if (and this.isStorehouse this.isTradeOrder)}}
                                    <div style="display: flex; flex-direction: column; gap: 4px; margin-top: 4px; border-top: 1px solid rgba(0,0,0,0.1); padding-top: 4px;">
                                        <div style="display: flex; gap: 4px; align-items: center;">
                                            <select class="storehouse-trade-choice" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}" 
                                                    style="height: 20px; font-size: 0.85em; flex: 1;" {{#if this.isAutoTrade}}disabled style="opacity: 0.5;"{{/if}}>
                                                <option value="procure" {{#if (eq this.tradeChoice "procure")}}selected{{/if}}>Procure Goods</option>
                                                <option value="sell" {{#if (eq this.tradeChoice "sell")}}selected{{/if}}>Sell Goods</option>
                                            </select>
                                            <input type="number" class="storehouse-trade-amount" value="{{this.tradeAmount}}" {{#if this.isAutoTrade}}disabled style="opacity: 0.5;"{{/if}}
                                                   data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}"
                                                   style="width: 50px; height: 20px; font-size: 0.85em;" title="GP amount to trade">
                                            <span style="font-size: 0.8em;">GP</span>
                                        </div>
                                        {{#unless this.isInherited}}
                                            <button type="button" data-action="donateToStorehouse" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}"
                                                    style="height: 20px; font-size: 0.75em; width: 100%;">
                                                <i class="fa-solid fa-box-open"></i> Donate Items to Coffers
                                            </button>
                                        {{/unless}}
                                    </div>
                                {{/if}}

                                {{#if (and this.isArcaneStudyCrafting this.progress)}}
                                    <div style="font-size: 0.7em; color: purple; margin-top: 2px;">Progress: {{this.progress}} / {{this.maxCraftTurns}} {{this.progressLabel}}</div>
                                {{/if}}
                                {{#if (and this.isSmithyCrafting this.progress)}}
                                    <div style="font-size: 0.7em; color: purple; margin-top: 2px;">Progress: {{this.progress}} / {{this.maxCraftTurns}} {{this.progressLabel}}</div>
                                {{/if}}
                                {{#if this.isGardenHarvesting}}
                                    <div style="width: 100%; display: flex; flex-direction: column; gap: 4px; margin-top: 5px;">
                                    {{#if this.harvestOptions.length}}
                                    <div class="garden-harvest-container" style="display: flex; align-items: center; gap: 5px;">
                                        {{#if this.isVastGarden}}<span style="font-size: 0.8em; color: #666; width: 45px;">Plot 1:</span>{{/if}}
                                        <select class="garden-harvest-select" 
                                                data-item-id="{{id}}" 
                                                data-is-inherited="{{isInherited}}" 
                                                data-is-flag="{{isFlag}}" 
                                                data-member-id="{{memberId}}"
                                                style="width: 100%; font-size: 0.85em;">
                                            <option value="">-- Choose Harvest --</option>
                                            {{#each harvestOptions}}
                                            <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                                            {{/each}}
                                        </select>
                                    </div>
                                    {{/if}}
                                    {{#if this.isVastGarden}}
                                        <div class="garden-harvest-container" style="display: flex; align-items: center; gap: 5px;">
                                            <span style="font-size: 0.8em; color: #666; width: 45px;">Plot 2:</span>
                                            <select class="garden-harvest-select-2" 
                                                    data-item-id="{{id}}" 
                                                    data-is-inherited="{{isInherited}}" 
                                                    data-is-flag="{{isFlag}}" 
                                                    data-member-id="{{memberId}}"
                                                    style="width: 100%; font-size: 0.85em;">
                                                <option value="">-- Choose Harvest --</option>
                                                {{#each harvestOptions2}}
                                                <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                                                {{/each}}
                                            </select>
                                        </div>
                                    {{/if}}
                                    </div>
                                {{/if}}
                                {{#if this.isGardenChangingType}}
                                    <div class="garden-change-type-container" style="margin-top: 5px;">
                                        <select class="garden-change-type-select" 
                                                data-item-id="{{id}}" 
                                                data-is-inherited="{{isInherited}}" 
                                                data-is-flag="{{isFlag}}" 
                                                data-member-id="{{memberId}}"
                                                style="width: 100%; font-size: 0.85em; {{#if this.isOrderLocked}}opacity: 0.6; cursor: not-allowed;{{/if}}"
                                                {{#if this.isOrderLocked}}disabled{{/if}}>
                                            <option value="">-- Choose New Type (3 Turns) --</option>
                                            {{#each changeTypeOptions}}
                                            <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                                            {{/each}}
                                        </select>
                                    </div>
                                    {{#if this.progress}}
                                        <div class="bastion-progress-bar" title="Turns spent: {{this.progress}} / 3" style="margin-top: 4px; height: 14px; background: rgba(0,0,0,0.1); border: 1px solid #7a7971; border-radius: 3px; position: relative; overflow: hidden; width: 100%;">
                                            <div class="fill" style="width: {{this.progressPct}}%; height: 100%; background: #4a86e8; border-right: 1px solid #7a7971; transition: width 0.5s;"></div>
                                            <span style="position: absolute; top: 0; left: 0; width: 100%; text-align: center; font-size: 0.8em; line-height: 14px; color: white; font-weight: bold; text-shadow: 0 0 2px black, 0 0 2px black, 0 0 2px black;">
                                                {{this.progress}} / 3 Turns
                                            </span>
                                        </div>
                                    {{/if}}
                                {{/if}}
                            {{/if}}
                    {{/if}}
                    
                    {{#if (and (eq this.itemName "Arcane Study") (not this.isBuilding))}}
                        <div style="font-size: 0.8em; color: purple; margin-top: 2px;">
                            <i class="fa-solid fa-sparkles"></i> <b>Passive:</b> Gain <i>Identify</i> charm after Long Rest.
                        </div>
                    {{/if}}

                    {{#if (and (eq this.itemName "Sanctuary") (not this.isBuilding))}}
                        <div style="font-size: 0.8em; color: #a32a22; margin-top: 2px;">
                            <i class="fa-solid fa-heart-pulse"></i> <b>Passive:</b> Gain <i>Healing Word</i> charm after Long Rest.
                        </div>
                    {{/if}}

                    {{#if this.isUnderConstruction}}
                        <div class="bastion-upgrade-bar" title="Construction progress: {{this.upgradeProgress}} / {{this.upgradeTurns}}" style="margin-top: 4px; height: 14px; background: rgba(0,0,0,0.1); border: 1px solid #7a7971; border-radius: 3px; position: relative; overflow: hidden; width: 100%;">
                            <div class="fill" style="width: {{this.upgradeProgressPct}}%; height: 100%; background: #f1c232; border-right: 1px solid #7a7971; transition: width 0.5s;"></div>
                            <span style="position: absolute; top: 0; left: 0; width: 100%; text-align: center; font-size: 0.8em; line-height: 14px; color: black; font-weight: bold; text-shadow: 0 0 3px white, 0 0 3px white;">
                                {{this.constructionLabel}}: {{this.upgradeProgress}} / {{this.upgradeTurns}} Turns
                            </span>
                        </div>
                    {{/if}}
                </div>
                </div>
                
                <div style="display: flex; gap: 2px; align-items: center; flex-shrink: 0;">
                    {{#if this.isEnlargeable}}
                        <button type="button" data-action="upgradeFacility" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}" style="width: auto; padding: 2px 6px; color: darkgoldenrod;" title="Enlarge Facility">
                            <i class="fa-solid fa-arrow-up-right-dots"></i>
                        </button>
                    {{/if}}

                    {{#if (eq this.itemName "Barrack")}}
                        <button type="button" data-action="toggleBarrackNaming" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}"
                            style="width: auto; padding: 2px 6px; color: {{#if this.promptNames}}green{{else}}gray{{/if}};"
                            title="Toggle Name Prompting ({{#if this.promptNames}}On{{else}}Off{{/if}})">
                            <i class="fa-solid fa-id-card"></i>
                        </button>
                    {{/if}}

                    {{#if (eq this.itemName "Storehouse")}}
                        <button type="button" data-action="toggleAutoTrade" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}"
                            style="width: auto; padding: 2px 6px; color: {{#if this.isAutoTrade}}green{{else}}gray{{/if}};"
                            title="Toggle Auto-Trade (Alternates buying/selling each turn) - Currently: {{#if this.isAutoTrade}}ON{{else}}OFF{{/if}}">
                            <i class="fa-solid fa-arrows-rotate"></i>
                        </button>
                    {{/if}}

                    <button type="button" data-action="selectFacilityLayout" data-item-id="{{this.id}}" 
                        style="width: auto; padding: 2px 6px; {{#if this.isLayoutActive}}background: #444; color: white;{{else}}color: #444;{{/if}}" 
                        title="Select to layout squares on grid">
                        <i class="fa-solid fa-pen-ruler"></i>
                    </button>
                    {{#unless this.isInherited}}
                    <button type="button" data-action="deleteFacility" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}" style="width: auto; padding: 2px 6px; color: darkred;" title="Demolish">
                        <i class="fa-solid fa-trash"></i>
                    </button>
                    {{/unless}}
                </div>
                </div>
            </li>
        {{/each}}
    </ul>
    </details>

    <details data-section="basic" style="margin-top: 5px; border-top: 1px solid #ccc; padding-top: 5px;" {{#if sectionStates.basic}}open{{/if}}>
        <summary style="cursor: pointer; font-weight: bold; font-size: 1em; color: #444; margin-bottom: 5px;" title="Click to toggle section">
            <i class="fa-solid fa-house"></i> Basic Facilities ({{basicFacilitiesBuilt.length}})
        </summary>
        <ul style="list-style: none; padding: 0; margin: 0;">
            {{#each basicFacilitiesBuilt}}
                <li class="facility-item {{#if this.isLayoutActive}}active-layout{{/if}}" style="margin-bottom: 3px; padding: 2px; background: rgba(0,0,0,0.02); border-radius: 3px; border-left: 3px solid {{this.facColor}}; {{#if this.isUnderConstruction}}opacity: 0.7;{{/if}}">
                    <div style="display: flex; align-items: center; justify-content: space-between;">
                        <div style="display: flex; align-items: center; gap: 6px;">
                            <img src="{{this.img}}" width="20" height="20" style="border-radius: 2px; {{#if this.isUnderConstruction}}filter: grayscale(1);{{/if}}">
                            <b style="font-size: 0.9em;">{{this.name}}</b>
                            <span style="font-size: 0.65em; background: #ddd; color: #333; padding: 1px 4px; border-radius: 2px;">{{this.size}}</span>
                        </div>
                        <div style="display: flex; gap: 2px;">
                            {{#if this.isEnlargeable}}
                                <button type="button" data-action="upgradeFacility" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}" style="padding: 2px 4px; font-size: 0.7em; color: darkgoldenrod;" title="Enlarge"><i class="fa-solid fa-arrow-up-right-dots"></i></button>
                            {{/if}}
                            <button type="button" data-action="selectFacilityLayout" data-item-id="{{this.id}}" style="padding: 2px 4px; font-size: 0.7em; {{#if this.isLayoutActive}}background: #444; color: white;{{/if}}" title="Layout"><i class="fa-solid fa-pen-ruler"></i></button>
                            {{#unless this.isInherited}}
                                <button type="button" data-action="deleteFacility" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}" style="padding: 2px 4px; font-size: 0.7em; color: darkred;" title="Demolish"><i class="fa-solid fa-trash"></i></button>
                            {{/unless}}
                        </div>
                    </div>
                    {{#if this.isUnderConstruction}}
                        <div class="bastion-upgrade-bar" title="Construction progress: {{this.upgradeProgress}} / {{this.upgradeTurns}}" style="margin: 4px 0 4px 26px; height: 12px; background: rgba(0,0,0,0.1); border: 1px solid #7a7971; border-radius: 3px; position: relative; overflow: hidden;">
                            <div class="fill" style="width: {{this.upgradeProgressPct}}%; height: 100%; background: #f1c232; border-right: 1px solid #7a7971; transition: width 0.5s;"></div>
                            <span style="position: absolute; top: 0; left: 0; width: 100%; text-align: center; font-size: 0.75em; line-height: 12px; color: black; font-weight: bold; text-shadow: 0 0 3px white, 0 0 3px white;">
                                {{this.constructionLabel}}: {{this.upgradeProgress}} / {{this.upgradeTurns}}
                            </span>
                        </div>
                    {{/if}}

                    <div style="font-size: 0.6em; padding-left: 26px; color: #777;">
                        Layout: {{this.placedSquares}} / {{this.maxSquares}} sq
                    </div>
                </li>
            {{/each}}
        </ul>
    </details>
    </div>
    </div>

    <div class="bastion-layout-designer" style="flex: 1; display: flex; flex-direction: column; padding-left: 15px;">
        <div class="bastion-tabs" style="display: flex; gap: 2px; margin-bottom: 5px;">
            <button type="button" data-action="switchTab" data-tab="map" class="{{#if (eq activeTab "map")}}active{{/if}}" style="flex: 1; padding: 5px; font-weight: bold; border-radius: 4px 4px 0 0; border: 1px solid #ccc; border-bottom: none; {{#if (eq activeTab "map")}}background: rgba(0,0,0,0.1);{{else}}background: rgba(0,0,0,0.05); opacity: 0.6;{{/if}}">
                <i class="fa-solid fa-map"></i> Bastion Map
            </button>
            <button type="button" data-action="switchTab" data-tab="info" class="{{#if (eq activeTab "info")}}active{{/if}}" style="flex: 1; padding: 5px; font-weight: bold; border-radius: 4px 4px 0 0; border: 1px solid #ccc; border-bottom: none; {{#if (eq activeTab "info")}}background: rgba(0,0,0,0.1);{{else}}background: rgba(0,0,0,0.05); opacity: 0.6;{{/if}}">
                <i class="fa-solid fa-circle-info"></i> Logistics Panel
            </button>
        </div>

        {{#if (eq activeTab "map")}}
        <div style="background: rgba(0,0,0,0.05); padding: 8px; border-radius: 4px; margin-bottom: 10px; border: 1px solid #ccc;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px;">
                <h3 style="margin: 0; font-size: 1.1em;"><i class="fa-solid fa-grid-2"></i> Layout Designer</h3>
                <div style="display: flex; gap: 5px;">
                    <select data-action="changeBackground" style="font-size: 0.75em; height: 24px; width: 100px;">
                        <option value="none" {{#if (eq gridBackground "none")}}selected{{/if}}>Plain Grid</option>
                        <option value="grass" {{#if (eq gridBackground "grass")}}selected{{/if}}>Grass</option>
                        <option value="stone" {{#if (eq gridBackground "stone")}}selected{{/if}}>Stone</option>
                        <option value="parchment" {{#if (eq gridBackground "parchment")}}selected{{/if}}>Parchment</option>
                    </select>
                    <button type="button" data-action="saveLayout" style="width: auto; padding: 3px 10px; font-size: 0.75em; background: rgba(0,120,0,0.15); border: 1px solid green;" title="Save current changes to database">
                        <i class="fa-solid fa-floppy-disk"></i> Save
                    </button>
                    <button type="button" data-action="clearLayout" style="width: auto; padding: 3px 8px; font-size: 0.75em; border: 1px solid #999;" title="Remove only your facilities from the local grid">
                        <i class="fa-solid fa-eraser"></i> Clear
                    </button>
                </div>
            </div>
            <div style="display: flex; justify-content: space-between; font-size: 0.85em;">
                <div style="display: flex; gap: 8px; align-items: center;">
                    <button type="button" data-action="buildDefensiveWall" style="width: auto; padding: 2px 4px; font-size: 0.85em;" title="Buy 5ft wall squares ({{wallCost}} GP, {{wallTime}} Days)">
                        <i class="fa-solid fa-plus"></i> Buy Walls
                    </button>
                    <button type="button" data-action="selectFacilityLayout" data-item-id="{{structIds.wall}}" 
                        style="width: auto; padding: 2px 5px; font-size: 0.85em; {{#if (eq selectedId structIds.wall)}}background: #444; color: white;{{/if}}" title="Draw walls">
                        <i class="fa-solid fa-wall-brick"></i> Walls: {{placedWallSquares}}/{{totalWallSquaresAllowed}}
                    </button>
                    <button type="button" data-action="selectFacilityLayout" data-item-id="{{structIds.path}}" 
                        style="width: auto; padding: 2px 5px; font-size: 0.85em; {{#if (eq selectedId structIds.path)}}background: #444; color: white;{{/if}}" title="Corridors/Ramps/Stairs (1 Turn)">
                        <i class="fa-solid fa-stairs"></i> Paths
                    </button>
                    <button type="button" data-action="selectFacilityLayout" data-item-id="{{structIds.closet}}" 
                        style="width: auto; padding: 2px 5px; font-size: 0.85em; {{#if (eq selectedId structIds.closet)}}background: #444; color: white;{{/if}}" title="Closets/Washrooms">
                        <i class="fa-solid fa-door-closed"></i> Closets
                    </button>
                    <div style="display: flex; gap: 2px; align-items: center; border: 1px solid #777; padding: 1px 3px; border-radius: 3px; background: rgba(0,0,0,0.05);">
                        <button type="button" data-action="selectFacilityLayout" data-item-id="{{selectedOpening}}" 
                            style="width: auto; padding: 2px 5px; font-size: 0.85em; border: none; background: {{#if (eq selectedId selectedOpening)}}#444; color: white;{{else}}transparent;{{/if}}" title="Place selected opening type">
                            <i class="fa-solid fa-door-open"></i>
                        </button>
                        <select name="opening-type" style="font-size: 0.75em; height: 18px; width: 80px; border: none; background: #333; color: #eee;">
                            <option value="Door" {{#if (eq selectedOpening "Door")}}selected{{/if}}>Door</option>
                            <option value="Window" {{#if (eq selectedOpening "Window")}}selected{{/if}}>Window</option>
                            <option value="Locked Door" {{#if (eq selectedOpening "Locked Door")}}selected{{/if}}>Locked</option>
                            <option value="Secret Door" {{#if (eq selectedOpening "Secret Door")}}selected{{/if}}>Secret</option>
                            <option value="Portcullis" {{#if (eq selectedOpening "Portcullis")}}selected{{/if}}>Portcullis</option>
                        </select>
                    </div>
                </div>
                <div style="text-align: right;">
                    {{#if selectedId}}
                        <span style="color: #a32a22; font-weight: bold; font-size: 0.9em;">Placing: {{#if (eq selectedId structIds.wall)}}Walls{{else}}{{#if (eq selectedId structIds.path)}}Paths{{else}}{{#if (eq selectedId structIds.closet)}}Closet{{else}}{{#if (eq selectedId selectedOpening)}}{{selectedOpening}}{{else}}{{#each specialFacilitiesBuilt}}{{#if (eq this.id ../selectedId)}}{{this.name}}{{/if}}{{/each}}{{#each basicFacilitiesBuilt}}{{#if (eq this.id ../selectedId)}}{{this.name}}{{/if}}{{/each}}{{/if}}{{/if}}{{/if}}{{/if}}</span>
                    {{else}}
                        <span style="font-style: italic; color: #666;">Select an item to begin...</span>
                    {{/if}}
                </div>
            </div>
        </div>
        
        <div class="bastion-grid" style="display: grid; grid-template-columns: repeat({{gridSize}}, 1fr); grid-template-rows: repeat({{gridSize}}, 1fr); gap: 1px; background: #666; border: 1px solid #333; aspect-ratio: 1/1; width: 100%; max-width: 440px; cursor: crosshair;
            {{#if (eq gridBackground "grass")}}background-image: linear-gradient(rgba(34,139,34,0.7), rgba(34,139,34,0.7)), url('ui/denim.png'); background-color: #2e7d32;{{/if}}
            {{#if (eq gridBackground "stone")}}background-image: url('ui/parchment.jpg'); filter: grayscale(1) brightness(0.5);{{/if}}
            {{#if (eq gridBackground "parchment")}}background-image: url('ui/parchment.jpg'); background-size: cover;{{/if}}">
            {{#each grid}}
                <div class="bastion-grid-square" 
                    data-coord="{{this.coord}}" 
                    title="{{#if this.name}}{{this.name}}{{else}}{{this.coord}}{{/if}}"
                    style="background: {{#if (and this.name (not this.isOpening))}}{{this.color}}{{else if this.isWall}}url('modules/dnd-2024-bastion-manager/assets/stone_texture.webp'){{else}}rgba(255,255,255,0.1){{/if}}; border-radius: 1px; position: relative; display: flex; align-items: center; justify-content: center;
                    {{#if this.isScaffolding}}background-image: repeating-linear-gradient(45deg, transparent, transparent 5px, rgba(255,255,255,0.2) 5px, rgba(255,255,255,0.2) 10px); opacity: 0.6;{{/if}}">
                    {{#if this.isOpening}}
                        <div style="width: 70%; height: 30%; background: {{this.color}}; border-radius: 1px; border: 1px solid rgba(255,255,255,0.3); z-index: 2;"></div>
                    {{/if}}
                    {{#if this.label}}
                        <span style="position: absolute; pointer-events: none; font-size: 9px; font-weight: bold; color: white; text-shadow: 0 0 2px black, 0 0 2px black; white-space: nowrap; z-index: 5; text-align: center;">{{this.label}}</span>
                    {{/if}}
                </div>
            {{/each}}
        </div>
        {{/if}}

        {{#if (eq activeTab "info")}}
            <div class="bastion-info-panel" style="flex: 1; background: rgba(0,0,0,0.03); color: #111; padding: 12px; border-radius: 4px; border: 1px solid #ccc; overflow-y: auto;">
                <h3 style="border-bottom: 2px solid #555; padding-bottom: 5px; margin-top: 0;"><i class="fa-solid fa-warehouse"></i> Bastion Logistics</h3>
                
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                    <!-- Column 1: Master Queue -->
                    <section>
                        <h4 style="color: #a32a22; border-bottom: 1px solid #ccc; padding-bottom: 2px; margin-bottom: 8px;">
                            <i class="fa-solid fa-hourglass-start"></i> Project Queues
                        </h4>
                        {{#if allActiveQueues.length}}
                            {{#each allActiveQueues}}
                                <details class="facility-queue-block" data-queue-id="{{this.id}}" {{#unless this.isQueueCollapsed}}open{{/unless}} style="margin-bottom: 8px; background: rgba(255,255,255,0.5); color: #111; padding: 6px; border-radius: 3px; border-left: 3px solid {{this.facColor}};">
                                    <summary style="cursor: pointer; font-weight: bold; font-size: 0.85em; display: flex; justify-content: space-between; align-items: center; margin-bottom: 3px; list-style: none;">
                                        <div style="display: flex; align-items: center; gap: 5px; flex: 1;">
                                            <i class="fa-solid fa-caret-{{#if this.isQueueCollapsed}}right{{else}}down{{/if}}" style="opacity: 0.5; width: 10px;"></i>
                                            <span>{{this.name}} <span style="font-weight: normal; color: #a32a22; margin-left: 5px;">({{this.queueTotalGold}} Gold, {{this.queueTotalTurns}} Turns)</span></span>
                                        </div>
                                        {{#unless this.isInherited}}
                                            <a data-action="clearQueue" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}" data-member-id="{{this.memberId}}" data-is-inherited="{{this.isInherited}}" 
                                               style="color: #666; font-size: 0.9em;" title="Clear Entire Queue">
                                                <i class="fa-solid fa-eraser"></i>
                                            </a>
                                        {{/unless}}
                                    </summary>
                                    <ul style="list-style: none; padding: 0; margin: 4px 0 0 15px; font-size: 0.8em;">
                                        {{#each this.craftQueue}}
                                            <li style="display: flex; justify-content: space-between; padding: 1px 0; border-top: 1px solid rgba(0,0,0,0.05);">
                                                <span style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><i class="fa-solid fa-caret-right" style="opacity: 0.3;"></i> {{this.label}}</span>
                                                <span style="font-style: italic; color: #666; margin-left: 4px; flex-shrink: 0;">
                                                    ({{this.goldCost}}gp, {{this.timeCost}}{{../progressLabel}}
                                                    {{#if (eq ../../calculationMode "days")}} ({{this.timeCostInTurns}}t){{/if}}
                                                    )
                                                </span>
                                            </li>
                                        {{/each}}
                                    </ul>
                                </details>
                            {{/each}}
                        {{else}}
                            <p style="font-style: italic; color: #777; font-size: 0.85em;">No items currently queued.</p>
                        {{/if}}
                    </section>

                    <!-- Column 2: Expected Output -->
                    <section>
                        <h4 style="color: #2e7d32; border-bottom: 1px solid #ccc; padding-bottom: 2px; margin-bottom: 8px;">
                            <i class="fa-solid fa-box-open"></i> Next Turn Forecast
                        </h4>
                        {{#if expectedOutputs.length}}
                            <ul style="list-style: none; padding: 0; margin: 0;">
                                {{#each expectedOutputs}}
                                    <li style="background: rgba(255,255,255,0.7); color: #111; margin-bottom: 4px; padding: 6px; border-radius: 3px; border-left: 3px solid #2e7d32; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">
                                        <div style="font-size: 0.7em; color: #555; text-transform: uppercase; font-weight: bold;">{{this.facName}}</div>
                                        <div style="font-size: 0.9em; font-weight: bold;">{{this.label}}</div>
                                    </li>
                                {{/each}}
                            </ul>
                            <div style="font-size: 0.75em; color: #666; margin-top: 8px; line-height: 1.2;">
                                <i class="fa-solid fa-circle-info"></i> These items are expected to be ready when the next Bastion Turn is advanced.
                            </div>
                        {{else}}
                            <p style="font-style: italic; color: #777; font-size: 0.85em;">No projects finishing next turn.</p>
                        {{/if}}
                    </section>
                </div>
            </div>
        {{/if}}
    </div>
</div>