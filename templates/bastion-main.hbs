                                    <button type="button" data-action="theaterAction" data-sub-action="join" data-actor-id="{{../actor.id}}" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}" style="width: auto; padding: 2px 8px; font-size: 0.85em; height: 26px; white-space: nowrap;">Join Roles</button>
                                {{/if}}
                                {{#if (eq this.theaterPhase "Idle")}}
                                    <button type="button" data-action="theaterAction" data-sub-action="start-writing" data-actor-id="{{../actor.id}}" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}" style="width: auto; padding: 2px 8px; font-size: 0.85em; height: 26px; white-space: nowrap;" title="Manually begin the writing phase">Start Writing</button>
                                    <button type="button" data-action="theaterAction" data-sub-action="invite-writer" data-actor-id="{{../actor.id}}" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}" style="width: auto; padding: 2px 8px; font-size: 0.85em; height: 26px; white-space: nowrap;" title="Post a call for a Composer/Writer to chat">Invite Writer</button>
                                {{/if}}
                                {{#unless (eq this.theaterPhase "Idle")}}
                                    <button type="button" data-action="theaterAction" data-sub-action="invite" data-actor-id="{{../actor.id}}" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}" style="width: auto; padding: 2px 8px; font-size: 0.85em; height: 26px; white-space: nowrap;" title="Post an invitation to chat">Send Invite</button>
                                    <button type="button" data-action="theaterAction" data-sub-action="reset" data-actor-id="{{../actor.id}}" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}" style="width: auto; padding: 2px 6px; font-size: 0.85em; height: 26px; white-space: nowrap;" title="Reset Production"><i class="fa-solid fa-clapperboard"></i></button>
                                {{/unless}}
                            </div>
                        </div>

                        {{#if (or (eq this.theaterPhase "Writing") (eq this.theaterPhase "Rehearsing"))}}
                            <div class="bastion-progress-bar" title="Days: {{this.theaterProgress}} / {{this.theaterPhaseDays}}" style="height: 10px; background: rgba(0,0,0,0.2); border: 1px solid #555; border-radius: 5px; position: relative; overflow: hidden; margin-bottom: 5px;">
                                <div class="fill" style="width: {{this.theaterProgressPct}}%; height: 100%; background: #82cfff; transition: width 0.5s;"></div>
                            </div>
                        {{/if}}

                        <div style="display: flex; flex-direction: column; gap: 3px; margin-top: 6px;">
                            {{#if (or this.isWritingPhase (eq this.theaterPhase "Idle"))}}
                                <div style="display: flex; justify-content: space-between;">
                                    <span><b>Current Writer(s):</b></span>
                                    {{#if this.theaterRoster.writer}}
                                        <span style="color: #82cfff;">{{this.theaterRoster.writer.name}}</span>
                                    {{else}}
                                        <span style="color: #777; font-style: italic;">None</span>
                                    {{/if}}
                                </div>
                                {{#if this.isWritingPhase}}
                                    <div style="display: flex; justify-content: space-between; align-items: center;">
                                        <span><b>Script Title:</b></span>
                                        <input type="text" class="theater-script-title" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}"
                                            value="{{this.theaterScriptTitle}}" placeholder="Untitled Script"
                                            style="width: 60%; font-size: 0.9em; height: 20px; padding: 0 4px; border: 1px solid #555; background: #222; color: #eee; border-radius: 3px;">
                                    </div>
                                {{/if}}
                            {{/if}}
                            
                            {{#if this.isActingPhase}}
                                {{#if this.theaterAuthor}}
                                    <div style="display: flex; justify-content: space-between; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 2px; margin-bottom: 2px;">
                                        <span><b>Author:</b></span>
                                        <span style="color: #82cfff; font-style: italic;">{{this.theaterAuthor}}</span>
                                    </div>
                                {{/if}}
                                <div style="display: flex; justify-content: space-between;">
                                    <span><b>Director:</b></span>
                                    {{#if this.theaterRoster.director}}
                                        <span style="color: {{#if this.theaterRoster.director.isHireling}}#777{{else}}#82cfff{{/if}};">{{this.theaterRoster.director.name}} {{#if this.theaterRoster.director.isHireling}}(Hireling){{/if}}</span>
                                    {{else}}
                                        <span style="color: #777; font-style: italic;">None (Hireling)</span>
                                    {{/if}}
                                </div>
                                <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                                    <span style="flex-shrink: 0;"><b>Performers:</b></span>
                                    <span style="text-align: right; color: {{#if this.theaterRoster.performers.length}}#82cfff{{else}}#777{{/if}};">
                                        {{#each this.theaterRoster.performers}}
                                            {{this.name}}{{#unless @last}}, {{/unless}}
                                        {{else}}
                                            <i style="font-style: italic;">None (Hirelings)</i>
                                        {{/each}}
                                    </span>
                                </div>
                            {{/if}}
                        </div>
                        
                        {{#if (eq this.theaterPhase "Performing")}}
                            <div style="color: #4caf50; font-weight: bold; margin-top: 6px;"><i class="fa-solid fa-circle-play"></i> Show is Live! (Award: {{this.theaterDieSize}} die)</div>
                        {{/if}}
                    </div>
                {{/if}}

                {{#if (and this.isArchive (not this.isBuilding))}}
                    <div style="font-size: 0.9em; color: #eee; border: 2px solid #005a9e; border-radius: 5px; padding: 8px; background: rgba(255,255,255,0.02); margin-top: 4px; width: 100%; box-sizing: border-box;">
                        <div style="margin-bottom: 4px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 2px;">
                            <i class="fa-solid fa-book-sparkles"></i> <b>Reference Library:</b> Reference books provide benefits while in the Bastion.
                        </div>
                        <ul style="list-style: none; padding-left: 0; margin: 0;">
                            {{#each this.archiveBooksList}}
                                <li style="margin-top: 4px;">
                                    <div style="color: #82cfff; font-weight: bold; font-size: 0.95em;"><i class="fa-solid fa-book" style="font-size: 0.8em;"></i> {{this.name}}</div>
                                    <div style="font-style: italic; opacity: 0.85; padding-left: 12px; line-height: 1.2; font-size: 0.95em;">{{{this.desc}}}</div>
                                </li>
                            {{/each}}
                        </ul>
                    </div>
                {{/if}}

                {{#if this.isMeditationChamber}}
                    <div style="font-size: 0.9em; color: #eee; border: 2px solid #82cfff; border-radius: 5px; padding: 8px; background: rgba(255,255,255,0.02); margin-top: 4px; width: 100%; box-sizing: border-box;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px;">
                            <span data-tooltip="When you next roll on the Bastion Events table, you may roll twice and choose either result. This benefit is consumed on use." style="cursor: help;"><i class="fa-solid fa-brain"></i> <b>Inner Peace:</b></span>
                            {{#if ../innerPeaceActive}}
                                <span style="color: #4caf50; font-weight: bold;">ACTIVE</span>
                            {{else}}
                                <span style="opacity: 0.6; font-style: italic;">Requires Empower</span>
                            {{/if}}
                        </div>
                        <hr style="opacity: 0.1; margin: 5px 0;">
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <span data-tooltip="Use an Empower order to activate Fortify Self, which adds double your Proficiency Bonus to saving throws with chosen abilities while in your Bastion." style="cursor: help;"><b>Fortify Self:</b></span>
                            <button type="button" data-action="toggleMeditation" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}" style="width: auto; padding: 2px 8px; font-size: 0.85em; height: 24px;">
                                Meditation
                            </button>
                        </div>
                    </div>
                {{/if}}

                {{#if this.isObservatory}}
                    <div style="font-size: 0.9em; color: #eee; border: 2px solid #c9a227; border-radius: 5px; padding: 8px; background: rgba(255,255,255,0.02); margin-top: 4px; width: 100%; box-sizing: border-box;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px;">
                            <span data-tooltip="While in your Bastion during a Long Rest, you receive the Observatory Charm: you can see through magical darkness up to 60 feet, you know when you are being magically observed, and you have advantage on saving throws against spells. This charm expires at the start of the next Bastion Turn." style="cursor: help;"><i class="fa-solid fa-star"></i> <b>Observatory Charm:</b></span>
                            {{#if this.observatoryCharmActive}}
                                <span style="color: #c9a227; font-weight: bold;">ACTIVE</span>
                            {{else}}
                                <span style="opacity: 0.6; font-style: italic;">Requires Long Rest</span>
                            {{/if}}
                        </div>
                        <hr style="opacity: 0.1; margin: 5px 0;">
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <span data-tooltip="Grant yourself the Observatory Charm after finishing a Long Rest in your Bastion. The charm is automatically removed when the next Bastion Turn advances." style="cursor: help; font-size: 0.88em; opacity: 0.75;">Long Rest in Bastion</span>
                            <button type="button" data-action="grantObservatoryCharm" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}" style="width: auto; padding: 2px 8px; font-size: 0.85em; height: 24px;">
                                {{#if this.observatoryCharmActive}}Refresh Charm{{else}}Grant Charm{{/if}}
                            </button>
                        </div>
                        <hr style="opacity: 0.1; margin: 5px 0;">
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <span data-tooltip="Use an Empower order to choose an Eldritch Discovery charm and bestow it on yourself or a creature of your choice." style="cursor: help; font-size: 0.88em; opacity: 0.75;">Empower: Eldritch Discovery</span>
                            <span style="font-size: 0.82em; opacity: 0.55; font-style: italic;">via Empower order</span>
                        </div>
                    </div>
                {{/if}}

                {{#if this.isArcaneStudyFac}}
                    <div style="font-size: 0.9em; color: #eee; border: 2px solid #b39ddb; border-radius: 5px; padding: 8px; background: rgba(255,255,255,0.02); margin-top: 4px; width: 100%; box-sizing: border-box;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px;">
                            <span data-tooltip="After each Long Rest in your Bastion, you may cast Identify as a Charm (no spell slot required). This charm expires at the start of the next Bastion Turn." style="cursor: help;"><i class="fa-solid fa-sparkles"></i> <b>Arcane Study Charm:</b></span>
                            {{#if this.arcaneStudyCharmActive}}
                                <span style="color: #b39ddb; font-weight: bold;">ACTIVE</span>
                            {{else}}
                                <span style="opacity: 0.6; font-style: italic;">Requires Long Rest</span>
                            {{/if}}
                        </div>
                        <hr style="opacity: 0.1; margin: 5px 0;">
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <span data-tooltip="Grant yourself the Arcane Study Charm after finishing a Long Rest in your Bastion. The charm is automatically removed when the next Bastion Turn advances." style="cursor: help; font-size: 0.88em; opacity: 0.75;">Long Rest in Bastion</span>
                            <button type="button" data-action="grantArcaneStudyCharm" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}" style="width: auto; padding: 2px 8px; font-size: 0.85em; height: 24px;">
                                {{#if this.arcaneStudyCharmActive}}Refresh Charm{{else}}Grant Charm{{/if}}
                            </button>
                        </div>
                    </div>
                {{/if}}

                {{#if this.isReliquaryFac}}
                    <div style="font-size: 0.9em; color: #eee; border: 2px solid #c9784e; border-radius: 5px; padding: 8px; background: rgba(255,255,255,0.02); margin-top: 4px; width: 100%; box-sizing: border-box;">
                        {{!-- Reliquary Charm row --}}
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px;">
                            <span data-tooltip="Use an Empower order to receive the Reliquary Charm. The charm expires at the start of the next Bastion Turn." style="cursor: help;"><i class="fa-solid fa-khanda"></i> <b>Reliquary Charm:</b></span>
                            {{#if this.reliquaryCharmActive}}
                                <span style="color: #c9784e; font-weight: bold;">ACTIVE</span>
                            {{else}}
                                <span style="opacity: 0.6; font-style: italic;">Requires Empower order</span>
                            {{/if}}
                        </div>
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <span style="font-size: 0.88em; opacity: 0.75;">After Long Rest in Bastion</span>
                            <button type="button" data-action="grantReliquaryCharm" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}" style="width: auto; padding: 2px 8px; font-size: 0.85em; height: 24px;">
                                {{#if this.reliquaryCharmActive}}Refresh Charm{{else}}Grant Charm{{/if}}
                            </button>
                        </div>
                        <hr style="opacity: 0.1; margin: 5px 0;">
                        {{!-- Talisman row --}}
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <span data-tooltip="Use a Harvest order to craft a Talisman. The Talisman is a permanent keepsake." style="cursor: help; font-size: 0.88em; opacity: 0.75;"><i class="fa-solid fa-diamond"></i> <b>Talisman:</b></span>
                            {{#if this.reliquaryTalismanActive}}
                                <span style="color: #c9a227; font-weight: bold; font-size: 0.88em;">CRAFTED</span>
                            {{else}}
                                <span style="font-size: 0.82em; opacity: 0.55; font-style: italic;">via Harvest order</span>
                            {{/if}}
                        </div>
                    </div>
                {{/if}}

                {{#if this.isDemiplane}}
                    <div style="font-size: 0.9em; color: #eee; border: 2px solid #7e57c2; border-radius: 5px; padding: 8px; background: rgba(255,255,255,0.02); margin-top: 4px; width: 100%; box-sizing: border-box;">
                        {{!-- Arcane Resilience row --}}
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px;">
                            <span data-tooltip="Use an Empower order to inscribe magical runes on the Demiplane's walls. Until they fade (7 days), you gain Temporary Hit Points equal to 5× your level after each Long Rest spent in the Demiplane." style="cursor: help;"><i class="fa-solid fa-circle-nodes"></i> <b>Arcane Resilience:</b></span>
                            {{#if this.demiplaneRunesActive}}
                                <span style="color: #b39ddb; font-weight: bold;">ACTIVE</span>
                            {{else}}
                                <span style="opacity: 0.6; font-style: italic;">Requires Empower</span>
                            {{/if}}
                        </div>
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <span style="font-size: 0.88em; opacity: 0.75;">After Long Rest in Demiplane</span>
                            <button type="button" data-action="grantDemiplaneThp" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}"
                                    {{#unless this.demiplaneRunesActive}}disabled{{/unless}}
                                    style="width: auto; padding: 2px 8px; font-size: 0.85em; height: 24px;">
                                Gain THP
                            </button>
                        </div>
                        <hr style="opacity: 0.1; margin: 5px 0;">
                        {{!-- Fabrication row --}}
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <span data-tooltip="While in the Demiplane, you can take a Magic action to create a nonmagical object (max 5 ft in any dimension, max 5 GP value, made of wood/stone/clay/porcelain/glass/paper/nonprecious crystal or metal). Once per Long Rest." style="cursor: help;"><i class="fa-solid fa-wand-sparkles"></i> <b>Fabrication:</b></span>
                            <button type="button" data-action="toggleFabrication" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}"
                                    style="width: auto; padding: 2px 8px; font-size: 0.85em; height: 24px; {{#if this.demiplanesFabricationUsed}}opacity: 0.55; font-style: italic;{{/if}}">
                                {{#if this.demiplanesFabricationUsed}}Used{{else}}Use{{/if}}
                            </button>
                        </div>
                    </div>
                {{/if}}

                {{#if this.isSanctum}}
                    <div style="font-size: 0.9em; color: #eee; border: 2px solid #c9a227; border-radius: 5px; padding: 8px; background: rgba(255,255,255,0.02); margin-top: 4px; width: 100%; box-sizing: border-box;">
                        {{!-- Sanctum Charm row --}}
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px;">
                            <span data-tooltip="After spending a Long Rest in your Bastion, you gain the Sanctum Charm: cast Heal once without expending a spell slot (lasts 7 days or until used). You cannot gain this Charm again while you still have it." style="cursor: help;"><i class="fa-solid fa-heart-pulse"></i> <b>Sanctum Charm:</b></span>
                            {{#if this.sanctumCharmActive}}
                                <span style="color: #c9a227; font-weight: bold;">ACTIVE</span>
                            {{else}}
                                <span style="opacity: 0.6; font-style: italic;">Not granted</span>
                            {{/if}}
                        </div>
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <span style="font-size: 0.88em; opacity: 0.75;">After Long Rest in Bastion</span>
                            <button type="button" data-action="grantSanctumCharm" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}"
                                    {{#if this.sanctumCharmActive}}disabled{{/if}}
                                    style="width: auto; padding: 2px 8px; font-size: 0.85em; height: 24px;">
                                Grant Charm
                            </button>
                        </div>
                        <hr style="opacity: 0.1; margin: 5px 0;">
                        {{!-- Fortifying Rites row --}}
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 3px;">
                            <span data-tooltip="Use an Empower order to designate a beneficiary. They gain Temporary Hit Points equal to your level after each Long Rest for 7 days. The beneficiary does not need to be in the Bastion." style="cursor: help;"><i class="fa-solid fa-cross"></i> <b>Fortifying Rites:</b></span>
                            {{#if this.sanctumFortifyingRitesActive}}
                                <span style="color: #c9a227; font-weight: bold;">ACTIVE</span>
                            {{else}}
                                <span style="opacity: 0.6; font-style: italic;">Requires Empower</span>
                            {{/if}}
                        </div>
                        {{#if this.sanctumBeneficiaryName}}
                        <div style="font-size: 0.85em; opacity: 0.75; margin-bottom: 4px;">Beneficiary: <b>{{this.sanctumBeneficiaryName}}</b></div>
                        {{/if}}
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 3px;">
                            <span style="font-size: 0.88em; opacity: 0.75;">After beneficiary's Long Rest</span>
                            <button type="button" data-action="grantSanctumRitesThp" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}"
                                    {{#unless this.sanctumFortifyingRitesActive}}disabled{{/unless}}
                                    style="width: auto; padding: 2px 8px; font-size: 0.85em; height: 24px;">
                                Grant THP
                            </button>
                        </div>
                        <hr style="opacity: 0.1; margin: 5px 0;">
                        {{!-- Sanctum Recall row --}}
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
                            <span data-tooltip="While the Sanctum exists, Word of Recall is always prepared. When cast, you can set the Sanctum as the destination. One creature that arrives gains the benefit of a Heal spell." style="cursor: help;"><i class="fa-solid fa-person-walking-arrow-right"></i> <b>Sanctum Recall:</b></span>
                            <span style="font-size: 0.8em; opacity: 0.65; font-style: italic;">Always available</span>
                        </div>
                        <div style="display: flex; gap: 4px;">
                            <button type="button" data-action="grantWordOfRecall" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}"
                                    data-tooltip="Add Word of Recall to your prepared spell list (one-time setup)"
                                    style="flex: 1; padding: 2px 6px; font-size: 0.82em; height: 24px;">
                                <i class="fa-solid fa-book-open"></i> Prepare Spell
                            </button>
                            <button type="button" data-action="applySanctumRecallHeal" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}"
                                    data-tooltip="Apply the benefit of a Heal spell to one creature that arrived via Word of Recall"
                                    style="flex: 1; padding: 2px 6px; font-size: 0.82em; height: 24px;">
                                <i class="fa-solid fa-heart-pulse"></i> Apply Heal
                            </button>
                        </div>
                    </div>
                {{/if}}

                {{#if this.isWarRoom}}
                    <div style="font-size: 0.9em; color: #eee; border: 2px solid #b71c1c; border-radius: 5px; padding: 8px; background: rgba(255,255,255,0.02); margin-top: 4px; width: 100%; box-sizing: border-box;">
                        {{!-- Lieutenant count / defense bonus --}}
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
                            <span data-tooltip="Each lieutenant housed in your Bastion reduces by 1 the number of dice rolled to determine Bastion Defender losses during an Attack event." style="cursor: help;"><i class="fa-solid fa-chess-rook" style="color: #ef5350;"></i> <b>Lieutenants:</b></span>
                            <span style="color: #ef9a9a; font-weight: bold;">{{this.warRoomLieutenantCount}} / 10</span>
                        </div>
                        {{#if this.warRoomLieutenantCount}}
                        <div style="font-size: 0.85em; opacity: 0.75; margin-bottom: 5px;">Attack dice reduced by <b>{{this.warRoomLieutenantCount}}</b> (6 → {{subtract 6 this.warRoomLieutenantCount}} dice pool)</div>
                        {{/if}}
                        {{#if this.warRoomLieutenantCount}}
                        <div style="font-size: 0.82em; opacity: 0.7; margin-bottom: 5px; font-style: italic;">
                            {{#each this.warRoomLieutenants}}{{#unless @first}}, {{/unless}}{{this.name}}{{/each}}
                        </div>
                        {{/if}}
                        {{#if this.warRoomArmyActive}}
                        <hr style="opacity: 0.15; margin: 5px 0;">
                        <div style="margin-bottom: 3px;"><i class="fa-solid fa-shield-halved" style="color: #ef5350;"></i> <b>Army:</b> <span style="color: #ef9a9a;">ACTIVE</span></div>
                        <div style="font-size: 0.85em; opacity: 0.8; margin-bottom: 2px;">{{this.warRoomArmyGuards}} Guards{{#if this.warRoomArmyMounted}} (mounted){{/if}}</div>
                        <div style="font-size: 0.85em; opacity: 0.8; margin-bottom: 2px;">Commander: <b>{{this.warRoomArmyLeaderName}}</b></div>
                        <div style="font-size: 0.85em; opacity: 0.75; margin-bottom: 5px;"><i class="fa-solid fa-coins" style="color: #c9a227;"></i> Upkeep: <b>{{this.warRoomArmyDailyCost}} GP/day</b> · <b>{{this.warRoomArmyWeeklyCost}} GP/week</b></div>
                        <button type="button" data-action="disbandWarRoomArmy" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}"
                                style="width: auto; padding: 2px 8px; font-size: 0.82em; height: 24px; background: rgba(100,0,0,0.4); color: #ef9a9a; border-color: #b71c1c;">
                            <i class="fa-solid fa-flag-checkered"></i> Disband Army
                        </button>
                        {{/if}}
                        <hr style="opacity: 0.1; margin: 5px 0;">
                        <div style="display: flex; gap: 4px;">
                            <button type="button" data-action="showWarRoomRoster" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}"
                                    style="flex: 1; padding: 2px 6px; font-size: 0.82em; height: 24px;">
                                <i class="fa-solid fa-chess-rook"></i> Lieutenant Roster
                            </button>
                        </div>
                    </div>
                {{/if}}

                {{#if this.isPub}}
