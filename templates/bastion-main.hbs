                                    <button type="button" data-action="theaterAction" data-sub-action="leave" data-actor-id="{{../actor.id}}" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}" style="width: auto; padding: 2px 8px; font-size: 0.85em; height: 26px; color: #f44336; border-color: rgba(244, 67, 54, 0.4); white-space: nowrap;" title="Leave your current role in this production">Leave Role</button>
