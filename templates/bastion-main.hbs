<div class="bastion-manager-container" style="display: flex; gap: 15px; height: 100%; overflow: hidden;">
    
    <div class="bastion-sidebar" style="flex: 0 0 370px; overflow-y: auto; padding-right: 10px; border-right: 1px solid #ccc; display: flex; flex-direction: column;">
    <div class="sidebar-content-column">
    <div class="bastion-header" style="text-align: center; margin-bottom: 5px;">
        <h2 style="margin-bottom: 5px; line-height: 1.2; display: flex; align-items: center; justify-content: center; gap: 6px;">
            <span>{{#if bastionName}}{{bastionName}}{{else}}{{actor.name}}'s Bastion{{/if}}</span>
            <button type="button" data-action="renameBastionName" style="width: auto; padding: 2px 4px; border: none; background: none; color: #888; cursor: pointer; font-size: 0.55em; line-height: 1;" title="Rename Bastion">
                <i class="fa-solid fa-pencil"></i>
            </button>
        </h2>
        <div style="font-size: 1em; display: flex; align-items: center; justify-content: center; gap: 15px; flex-wrap: wrap;">
            <span><b>Total Turns:</b> {{turnCount}}</span>

            {{#if neglectWarning}}
                <span class="neglect-warning" style="color: {{neglectColor}}; font-weight: bold; display: flex; align-items: center; gap: 4px;" 
                    title="Neglect Counter: {{neglectCounter}} / {{actorLevel}} turns. If this reaches {{actorLevel}} without an order being issued, the Bastion is lost.">
                    <i class="fa-solid fa-triangle-exclamation"></i> 
                    Decaying ({{neglectCounter}}/{{actorLevel}})
                    <i class="fa-solid fa-circle-info" style="font-size: 0.8em; opacity: 0.7;" title="NEGLECT RULES: If no orders are issued for a number of consecutive turns equal to your level, the Bastion is abandoned and looted. Issuing any order other than 'Maintain' resets this counter."></i>
                </span>
            {{/if}}

            {{#if fortifiedSaves.length}}
                <span style="color: #4a86e8; font-weight: bold; display: flex; align-items: center; gap: 4px;" title="Advantage on {{#each fortifiedSaves}}{{this}}{{#unless @last}}, {{/unless}}{{/each}} saves.">
                    <i class="fa-solid fa-shield-halved"></i> Fortified
                </span>
            {{/if}}

            {{#if (ne actor.type "group")}}
                <button type="button" data-action="toggleCombine" style="width: auto; padding: 2px 8px; font-size: 0.75em; {{#if combinedGroup}}color: green; font-weight: bold;{{/if}}" 
                    title="{{#if combinedGroup}}Combined with {{combinedGroup.name}}{{else}}Combine this Bastion with a shared Group Bastion{{/if}}">
                    <i class="fa-solid fa-people-group"></i> {{#if combinedGroup}}Combined{{else}}Combine{{/if}}
                </button>
            {{/if}}
            
            <div style="display: flex; gap: 5px; align-items: center; border: 1px solid #ccc; padding: 4px; border-radius: 4px; background: rgba(0,0,0,0.05);">
                <button type="button" data-action="maintainAll" style="width: auto; height: auto !important; padding: 3px 8px; font-size: 0.75em;" title="Set all facilities to Maintain">
                    <i class="fa-solid fa-broom"></i> Maintain All
                </button>
            
                {{#if canAdvanceTurn}}
                    <span style="border-left: 1px solid #ccc; height: 20px; margin: 0 5px;"></span>
                    {{#if calendarDrivenTurns}}
                        {{#if ordersIssued}}
                            <span style="font-size: 0.8em; color: #555; font-style: italic; display: flex; align-items: center; gap: 4px;">
                                <i class="fa-solid fa-hourglass-half"></i> Orders Pending{{#if ordersCountdown}} ({{ordersCountdown}}d){{/if}}
                            </span>
                            {{#if isGM}}
                                <button type="button" data-action="cancelOrders" style="width: auto; padding: 2px 8px; font-size: 0.75em; color: #a32a22;" title="Cancel pending orders — the turn will not resolve automatically">
                                    <i class="fa-solid fa-xmark"></i> Cancel
                                </button>
                            {{/if}}
                        {{else}}
                            <button type="button" data-action="issueOrders" style="width: auto; height: auto !important; padding: 3px 8px; font-size: 0.75em; color: #2e7d32;" title="Lock in current orders. The turn resolves automatically once enough in-game time passes.">
                                <i class="fa-solid fa-scroll"></i> Issue Orders ({{readyCount}}/{{totalBastions}})
                            </button>
                        {{/if}}
                    {{else}}
                        <div style="display: flex; gap: 0; align-items: center; border: 1px solid #777; border-radius: 4px; overflow: hidden; background: white;">
                            <button type="button" data-action="toggleAdvanceMode" style="width: auto; padding: 2px 6px; border: none; border-right: 1px solid #777; background: {{#if (eq advanceMode "global")}}#2e7d32{{else}}none{{/if}}; color: {{#if (eq advanceMode "global")}}white{{else}}#666{{/if}}; border-radius: 0;" title="Global Mode: Advance all active Bastions">
                                <i class="fa-solid fa-earth-americas"></i>
                            </button>
                            <button type="button" data-action="toggleAdvanceMode" style="width: auto; padding: 2px 6px; border: none; background: {{#if (eq advanceMode "individual")}}#a32a22{{else}}none{{/if}}; color: {{#if (eq advanceMode "individual")}}white{{else}}#666{{/if}}; border-radius: 0;" title="Individual Mode: Advance ONLY this character (Catch-up)">
                                <i class="fa-solid fa-person-running"></i>
                            </button>
                        </div>
                        <input type="number" name="turns" value="1" min="1" style="width: 30px; text-align: center; height: 20px; font-size: 0.8em; border: 1px solid #777;" title="Turns to advance">
                        {{#if (eq advanceMode "global")}}
                            <button type="button" data-action="advanceGlobalTurn" style="width: auto; height: auto !important; padding: 3px 8px; font-size: 0.75em; color: #2e7d32;" title="Process all Bastions owned by logged-in players">
                                <i class="fa-solid fa-play"></i> Run Turn ({{readyCount}}/{{totalBastions}})
                            </button>
                        {{else}}
                            <button type="button" data-action="advanceIndividualTurn" style="width: auto; padding: 2px 8px; font-size: 0.75em; color: #a32a22;" title="Process only this character's Bastion">
                                <i class="fa-solid fa-person-running"></i> Run Catch-up
                            </button>
                        {{/if}}
                    {{/if}}
                {{else}}
                    {{#if (ne actor.type "group")}}
                        <span style="border-left: 1px solid #ccc; height: 20px; margin: 0 5px;"></span>
                        <button type="button" data-action="toggleReady" style="width: auto; padding: 2px 8px; font-size: 0.75em; {{#if isReady}}background: #2e7d32; color: white;{{/if}}" title="Signal to DM that you are ready for the next turn">
                            <i class="fa-solid fa-check-to-slot"></i> {{#if isReady}}Ready!{{else}}Mark Ready{{/if}}
                        </button>
                    {{/if}}
                {{/if}}
                {{#if isGM}}
                    <span style="border-left: 1px solid #ccc; height: 20px; margin: 0 5px;"></span>
                    <button type="button" data-action="toggleFreeMode"
                        style="width: auto; height: auto !important; padding: 3px 8px; font-size: 0.75em; {{#if freeMode}}background: #7b1fa2; color: white; font-weight: bold;{{else}}color: #888;{{/if}}"
                        title="Free Mode: Orders complete instantly with no gold or items consumed">
                        <i class="fa-solid fa-wand-magic-sparkles"></i> {{#if freeMode}}Free Mode ON{{else}}Free Mode{{/if}}
                    </button>
                {{/if}}
            </div>
        </div>
        
        <div style="font-size: 0.85em; color: #444; margin-top: 6px; border-top: 1px solid #ddd; padding-top: 5px;">
            <div style="display: flex; align-items: center; gap: 6px;">
                <span style="font-weight: bold; text-transform: uppercase; font-size: 0.8em; letter-spacing: 0.04em;"><i class="fa-solid fa-shield" style="color:#a32a22;"></i> Defenders</span>
                <button type="button" data-action="viewGraveyard" style="width: auto; padding: 1px 3px; border: none; background: none; color: #888; cursor: pointer; font-size: 0.9em;" title="View Memorial Wall (Fallen Defenders)">
                    <i class="fa-solid fa-tombstone"></i>
                </button>
            </div>
            {{#if defendersByFacility.length}}
                <div style="margin-top: 3px; display: flex; flex-direction: column; gap: 2px;">
                {{#each defendersByFacility}}
                    <div style="display: flex; flex-wrap: wrap; gap: 2px; align-items: center;">
                        <b>{{this.facilityName}}:</b>&nbsp;{{this.count}}
                        {{#each this.names}}
                            <span style="display: inline-flex; align-items: center; gap: 1px;">
                                &nbsp;— {{this}}
                                <button type="button" data-action="renameDefender" data-item-id="{{../id}}" data-is-flag="{{../isFlag}}" data-index="{{@index}}"
                                        style="width: auto; padding: 0 2px; font-size: 0.75em; height: 14px; border: none; background: none; color: #888; cursor: pointer; line-height: 1;" title="Rename defender">
                                    <i class="fa-solid fa-pen" style="font-size: 0.7em;"></i>
                                </button>
                            </span>
                        {{/each}}
                    </div>
                {{/each}}
                </div>
            {{else}}
                <div style="margin-top: 3px; opacity: 0.6; font-style: italic;">Bastion is undefended.</div>
            {{/if}}
        </div>
    </div>

    <hr style="margin: 5px 0;">

    {{#if isNewBastion}}
        <div class="bastion-welcome-splash" style="padding: 12px; text-align: center; background: rgba(128,0,128,0.05); border: 2px dashed purple; border-radius: 8px; margin: 10px 0;">
            <i class="fa-solid fa-chess-rook" style="font-size: 2.5em; color: purple; margin-bottom: 8px; opacity: 0.8;"></i>
            <h3 style="border: none; margin-bottom: 4px; font-size: 1.2em;">Found Your Bastion</h3>
            <p style="font-size: 0.85em; color: #444; margin-bottom: 12px;">Welcome to level 5! You may established your first four facilities <b>instantly and for free</b>.</p>
            <div style="display: flex; justify-content: center;">
                <button type="button" data-action="initializeBastion" style="width: auto; padding: 8px 20px; font-weight: bold; background: purple; color: white; cursor: pointer; border: none; border-radius: 4px;">
                    <i class="fa-solid fa-sparkles"></i> Quick-Start Founding
                </button>
            </div>
        </div>
    {{/if}}

    {{#if (ne actor.type "group")}}<div class="bastion-build-section" style="margin-bottom: 8px; display: flex; gap: 5px;">
        <select name="compendium-facility" style="flex-grow: 1;">
            <option value="">-- Select Facility to Build --</option>
            {{#each specialFacilities}}
                <optgroup label="Level {{this.level}}">
                {{#each this.facilities}}
                    <option value="{{this._id}}">
                        {{this.name}}{{#if this.prerequisite}}&nbsp;&nbsp; — &nbsp;&nbsp;{{this.prerequisite}}{{/if}}
                    </option>
                {{/each}}
                </optgroup>
            {{/each}}
            {{#if basicFacilities.length}}
                <optgroup label="Basic Facilities">
                {{#each basicFacilities}}
                    <option value="{{this._id}}">
                        {{this.name}}
                    </option>
                {{/each}}
                </optgroup>
            {{/if}}
        </select>
        <button type="button" data-action="buildFromDropdown" style="width: auto; padding: 4px 10px;">
            <i class="fa-solid fa-hammer"></i> Build
        </button>
    </div>{{/if}}

    {{#if combinedGroup}}
        <div style="background: rgba(0, 100, 200, 0.05); border: 1px solid #005a9e; padding: 6px; border-radius: 4px; margin-bottom: 10px; font-size: 0.85em; text-align: center; color: #004578;">
            <i class="fa-solid fa-link"></i> Linked to <b>{{combinedGroup.name}}</b>
        </div>
        {{/if}}

    <details data-section="special" {{#if sectionStates.special}}open{{/if}}>
        <summary style="cursor: pointer; border-bottom: 1px solid #ccc; margin-bottom: 5px;" title="Click to toggle section">
            <h3 style="display: inline; font-size: 1.1em;">Special Facilities ({{specialFacilitiesBuilt.length}})</h3>
        </summary>
    <ul style="list-style: none; padding: 0; margin: 0;">
        {{#each specialFacilitiesBuilt}}
            <li class="facility-item {{#if this.isLayoutActive}}active-layout{{/if}}" style="margin-bottom: 4px; padding: 3px; background: {{#if this.isLayoutActive}}rgba(0,0,0,0.12){{else}}rgba(0,0,0,0.02){{/if}}; border-radius: 3px; border-left: 4px solid {{this.facColor}}; {{#if this.isUnderConstruction}}opacity: 0.7;{{/if}}; display: flex; flex-direction: column; gap: 5px;">
                <div style="display: flex; align-items: flex-start; justify-content: space-between; width: 100%;">
                <div style="display: flex; gap: 6px; flex: 1;">
                <img src="{{this.img}}" width="24" height="24" style="border: none; border-radius: 3px; vertical-align: middle; {{#if this.isUnderConstruction}}filter: grayscale(1);{{/if}}">
                
                    <div style="flex: 1;">
                    <b style="font-size: 0.95em;">{{this.name}}</b> 
                    {{#if this.isDamaged}}
                        <span style="font-size: 0.7em; background: #a32a22; color: white; padding: 1px 4px; border-radius: 3px; margin-left: 4px; vertical-align: middle;">DAMAGED</span>
                    {{/if}}
                    
                    <span style="font-size: 0.7em; background: {{#if (eq this.size "Construction")}}#a32a22; color: white;{{else}}#ddd; color: #333;{{/if}} padding: 1px 4px; border-radius: 3px; margin-left: 4px; vertical-align: middle;">{{this.size}}</span>
                    {{#if (and (or this.progress this.isCrafting) (not this.isBuilding) (not this.isDamaged) (not this.isOrderChanging))}}
                        <span style="font-size: 0.65em; background: #2e7d32; color: white; padding: 1px 5px; border-radius: 3px; margin-left: 4px; vertical-align: middle; animation: pulse 2s infinite;" title="Facility is currently working on a project">
                            <i class="fa-solid fa-gear fa-spin" style="font-size: 0.8em;"></i> WORKING
                        </span>
                    {{/if}}
                    {{#if this.subType}}
                        <span style="font-size: 0.8em; color: darkgreen; margin-left: 5px; font-weight: bold;">[{{this.subType}}]</span>
                    {{/if}}

                    {{#if this.hirelingsArr.length}}
                        <div style="font-size: 0.85em; color: #555; font-style: italic; display: flex; flex-wrap: wrap; gap: 2px; align-items: center; margin-top: 1px;">
                            <span>Hirelings:</span>
                            {{#each this.hirelingsArr}}
                                <span style="display: inline-flex; align-items: center; gap: 1px; background: rgba(0,0,0,0.05); padding: 0 3px; border-radius: 3px;">
                                    {{this}}
                                    <button type="button" data-action="renameHireling" data-item-id="{{../id}}" data-is-flag="{{../isFlag}}" data-index="{{@index}}"
                                            style="width: auto; padding: 0 2px; font-size: 0.75em; height: 14px; border: none; background: none; color: #888; cursor: pointer; line-height: 1;" title="Rename hireling">
                                        <i class="fa-solid fa-pen" style="font-size: 0.7em;"></i>
                                    </button>
                                </span>
                            {{/each}}
                        </div>
                    {{/if}}

                    {{#if (and this.isGreenhouse (not this.isBuilding))}}
                        <div style="font-size: 0.8em; color: #2e7d32; margin-top: 4px; border-top: 1px solid rgba(0,0,0,0.1); padding-top: 4px;">
                            <div style="display: flex; justify-content: space-between; align-items: center;">
                                <span><i class="fa-solid fa-seedling"></i> <b>Magical Fruits:</b> {{this.greenhouseFruitCount}} / 3</span>
                                <div style="display: flex; gap: 4px;">
                                    {{#if this.fruitUuid}}
                                        <button type="button" data-action="previewItem" data-uuid="{{this.fruitUuid}}" style="width: auto; padding: 0 4px; font-size: 0.8em; height: 18px;" title="View Fruit Details"><i class="fa-solid fa-eye"></i></button>
                                    {{/if}}
                                    {{#if (gt this.greenhouseFruitCount 0)}}
                                        <button type="button" data-action="consumeGreenhouseFruit" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}" style="width: auto; padding: 0 6px; font-size: 0.8em; height: 18px;" title="Harvest one fruit to inventory">Harvest</button>
                                    {{/if}}
                                    <button type="button" data-action="refreshGreenhouseFruits" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}" style="width: auto; padding: 0 4px; font-size: 0.8em; height: 18px;" title="Reset fruits (Daily at Dawn)"><i class="fa-solid fa-sun"></i></button>
                                </div>
                            </div>
                            <p style="font-size: 0.9em; opacity: 0.8; margin: 2px 0; font-style: italic;">Benefit: <i>Lesser Restoration</i>.</p>
                        </div>
                    {{/if}}

                    {{#if this.isArmory}}
                        <div style="margin-top: 2px;">
                            {{#if (and this.isStocked this.isFullyStocked)}}
                                <span style="font-size: 0.7em; background: #2e7d32; color: white; padding: 1px 6px; border-radius: 10px; font-weight: bold;" data-tooltip="All {{this.stockedCount}} defender(s) equipped. Attack event: {{this.armoryAttackFormula}} — each 1 rolled kills a defender."><i class="fa-solid fa-shield-check"></i> STOCK-READY ({{this.stockedCount}}/{{this.armoryTotalDefenders}})</span>
                            {{else if this.stockedCount}}
                                <span style="font-size: 0.7em; background: #e65100; color: white; padding: 1px 6px; border-radius: 10px; font-weight: bold;" data-tooltip="{{this.stockedCount}} of {{this.armoryTotalDefenders}} defender(s) equipped. Attack event: {{this.armoryAttackFormula}} — each 1 rolled kills a defender. Run a Trade order to fully stock (improves to 6d8)."><i class="fa-solid fa-shield-halved"></i> SEMI-STOCKED ({{this.stockedCount}}/{{this.armoryTotalDefenders}})</span>
                            {{else}}
                                <span style="font-size: 0.7em; background: #666; color: white; padding: 1px 6px; border-radius: 10px; font-weight: bold; opacity: 0.8;" data-tooltip="No defenders equipped. Attack event: 6d6 — each 1 rolled kills a defender. If none survive, a special facility is damaged. Run a Trade order to stock (upgrades dice to d8s)."><i class="fa-solid fa-shield-slash"></i> UNSTOCKED (0/{{this.armoryTotalDefenders}})</span>
                            {{/if}}
                        </div>
                    {{/if}}

                    <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-top: 1px;">
                        <div style="font-size: 0.65em; color: #666;">
                            <i class="fa-solid fa-layer-group"></i> Layout: 
                            <span style="{{#if (eq this.placedSquares this.maxSquares)}}color: green; font-weight: bold;{{/if}}">
                                {{this.placedSquares}} / {{this.maxSquares}} sq
                            </span>
                        </div>
                        {{#if this.isStorehouse}}
                            <div style="font-size: 0.65em; color: #555; text-align: right;" title="Current Stock / Maximum Capacity">
                                <i class="fa-solid fa-boxes-stacked"></i> <b>{{this.storedGp}} / {{this.storehouseLimit}} GP</b> (+{{this.storehouseMarkup}}%)
                            </div>
                        {{else if this.craftQueue.length}}
                            <div style="font-size: 0.65em; color: #555; text-align: right;" title="Project Queue Summary">
                                <i class="fa-solid fa-list-ol"></i> <b>Queue:</b> {{this.queueTotalGold}}g, {{this.queueTotalTurns}}t
                            </div>
                        {{/if}}
                    </div>

                    {{#if this.hasOrders}}
                        <div style="font-size: 0.85em; margin-top: 2px; display: flex; align-items: center; gap: 4px; flex-wrap: wrap; width: 100%;">
                            {{#if this.showOrderDropdown}}
                                <label>Order: </label>
                                <select class="facility-order-select" data-item-id="{{this.id}}" data-item-name="{{this.itemName}}" data-is-flag="{{this.isFlag}}" data-is-inherited="{{this.isInherited}}" data-member-id="{{this.memberId}}" {{#if this.isOrderDisabled}}disabled{{/if}} style="flex: 1;">
                                    {{#each this.orderOptions}}
                                        <option value="{{this.value}}" {{#if this.selected}}selected{{/if}} style="font-size: 0.9em;">{{this.label}}</option>
                                    {{/each}}
                                </select>
                                {{#if this.isTrinketTrophyResearching}}
                                    <div style="width: 100%; margin-top: 2px; font-size: 0.8em; opacity: 0.75; font-style: italic; line-height: 1.4;">
                                        <i class="fa-solid fa-dice"></i> After 7 days, roll any die — <b>even</b>: hireling finds a Common magic implement; <b>odd</b>: nothing found.
                                    </div>
                                {{else if this.isLibraryResearching}}
                                    <div style="width: 100%; margin-top: 2px;">
                                        {{#if this.isPubResearching}}
                                            <label style="font-size: 0.8em; opacity: 0.7; display: block; margin-bottom: 1px;">Creature to locate (leave blank for general rumours within 10 miles):</label>
                                            <input type="text" class="library-topic-input" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}" data-is-inherited="{{this.isInherited}}" data-member-id="{{this.memberId}}" value="{{this.libraryTopic}}"
                                                placeholder="e.g. Zevlor the Tiefling — last seen near Baldur's Gate"
                                                style="height: 20px; font-size: 0.85em; width: 100%; box-sizing: border-box;">
                                        {{else if this.isTrophyResearching}}
                                            <label style="font-size: 0.8em; opacity: 0.7; display: block; margin-bottom: 1px;">Subject of legendary significance to research:</label>
                                            <input type="text" class="library-topic-input" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}" data-is-inherited="{{this.isInherited}}" data-member-id="{{this.memberId}}" value="{{this.libraryTopic}}"
                                                placeholder="e.g. The Eye of Vecna — yields a Legend Lore–style summary if legendary"
                                                style="height: 20px; font-size: 0.85em; width: 100%; box-sizing: border-box;">
                                        {{else if this.isArchiveResearching}}
                                            <label style="font-size: 0.8em; opacity: 0.7; display: block; margin-bottom: 1px;">Subject of legendary significance to research:</label>
                                            <input type="text" class="library-topic-input" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}" data-is-inherited="{{this.isInherited}}" data-member-id="{{this.memberId}}" value="{{this.libraryTopic}}"
                                                placeholder="e.g. Strahd von Zarovich — yields a Legend Lore–style summary if legendary"
                                                style="height: 20px; font-size: 0.85em; width: 100%; box-sizing: border-box;">
                                        {{else}}
                                            <label style="font-size: 0.8em; opacity: 0.7; display: block; margin-bottom: 1px;">Topic to research (up to 3 accurate facts):</label>
                                            <input type="text" class="library-topic-input" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}" data-is-inherited="{{this.isInherited}}" data-member-id="{{this.memberId}}" value="{{this.libraryTopic}}"
                                                placeholder="e.g. The Cult of the Dragon — history, goals, key members"
                                                style="height: 20px; font-size: 0.85em; width: 100%; box-sizing: border-box;">
                                        {{/if}}
                                    </div>
                                {{/if}}
                                {{#if this.isArcaneStudyCrafting}}
                                    <div style="display: flex; flex-direction: column; gap: 4px; margin-top: 2px; width: 100%; {{#if this.isContinuingProject}}display: none;{{/if}}">
                                        {{#if (and this.showArcanaItemSelect (not this.isContinuingProject))}}
                                            <div style="display: flex; align-items: center; gap: 4px;">
                                                <select class="arcane-study-item-select" data-item-id="{{this.id}}" data-is-flag="{{this.isFlag}}" data-is-inherited="{{this.isInherited}}" data-member-id="{{this.memberId}}" style="height: 20px; font-size: 0.85em; flex: 1;" {{#if this.isSelectionDisabled}}disabled{{/if}}>
                                                    <option value="">-- Select Magic Item --</option>
                                                    {{#each magicItemOptions}}
                                                        {{#if this.groupOptions}}
                                                            <optgroup label="{{this.label}}">
                                                                {{#each this.groupOptions}}
                                                                    <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                                                                {{/each}}
                                                            </optgroup>
                                                        {{else}}
                                                            <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                                                        {{/if}}
                                                    {{/each}}
                                                </select>
                                                {{#if this.magicItemUuid}}
                                                    <a class="content-link" data-action="previewItem" data-uuid="{{this.magicItemUuid}}" draggable="true" style="font-size: 0.9em; height: 20px; display: flex; align-items: center; border: none; background: none;" title="View Item Details">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                {{/if}}
