                                        {{#if (and this.craftChoice (not this.isInherited) (not this.isContinuingProject))}}
                                            <button type="button" data-action="addToQueue" data-item-id="{{this.id}}" style="height: 20px; font-size: 0.75em; margin-top: 2px;">
