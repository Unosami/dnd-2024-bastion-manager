<div style="display: flex; flex-direction: column; gap: 10px; height: 100%; font-family: var(--font-primary); overflow: hidden;">
    
    <p style="font-size: 0.85em; color: var(--color-text-dark-secondary); margin: 0 0 10px 0; line-height: 1.3; flex-shrink: 0;">
        Select sources or specific facilities to hide them from the "Build Facility" dropdown. 
        <br><i>Note: Banning a source will hide all facilities from that source.</i>
    </p>

    <div style="flex-shrink: 0; background: rgba(0, 0, 0, 0.05); border: 1px solid var(--color-border-light-2); border-radius: 4px; padding: 8px; margin-bottom: 5px;">
        <h3 style="margin: 0 0 8px 0; font-size: 1.1em; border-bottom: 1px solid var(--color-border-light-1); padding-bottom: 3px;">
            <i class="fa-solid fa-book"></i> Sources
        </h3>
        {{#if sources.length}}
            <div style="display: flex; flex-wrap: wrap; gap: 10px;">
                {{#each sources}}
                <label style="display: flex; align-items: center; gap: 4px; cursor: pointer; padding: 2px 6px; border-radius: 3px; font-size: 0.9em; transition: background 0.2s;" onmouseover="this.style.background='rgba(0,0,0,0.05)'" onmouseout="this.style.background='transparent'">
                    <input type="checkbox" name="source_{{this.name}}" {{#if this.excluded}}checked{{/if}} style="margin: 0;">
                    <span>Exclude <b>{{this.name}}</b></span>
                </label>
                {{/each}}
            </div>
        {{else}}
            <p style="font-style: italic; color: var(--color-text-dark-secondary); margin: 0; font-size: 0.85em;">No defined sources found.</p>
        {{/if}}
    </div>

    <div style="flex-grow: 1; display: flex; flex-direction: column; background: rgba(0, 0, 0, 0.02); border: 1px solid var(--color-border-light-2); border-radius: 4px; padding: 8px; overflow: hidden;">
        <h3 style="margin: 0 0 8px 0; font-size: 1.1em; border-bottom: 1px solid var(--color-border-light-1); padding-bottom: 3px; flex-shrink: 0;">
            <i class="fa-solid fa-hammer"></i> Specific Facilities
        </h3>
        
        <div style="overflow-y: auto; padding-right: 5px; flex-grow: 1;">
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 6px;">
                {{#each facilities}}
                <label style="display: flex; align-items: flex-start; gap: 6px; cursor: pointer; padding: 4px 6px; border: 1px solid var(--color-border-light-2); border-radius: 3px; background: transparent; transition: all 0.2s;" onmouseover="this.style.borderColor='var(--color-border-dark)'; this.style.background='rgba(255, 255, 255, 0.05)'" onmouseout="this.style.borderColor='var(--color-border-light-2)'; this.style.background='transparent'">
                    <input type="checkbox" name="fac_{{this.id}}" {{#if this.excluded}}checked{{/if}} style="margin: 2px 0 0 0;">
                    <div style="display: flex; flex-direction: column; line-height: 1.1;">
                        <span style="font-weight: bold; font-size: 0.85em; color: var(--color-text-light-primary);">{{this.name}}</span>
                        <span style="color: var(--color-text-light-primary); font-size: 0.75em; opacity: 0.75;">{{this.source}}</span>
                    </div>
                </label>
                {{/each}}
            </div>
        </div>
    </div>
    
    <footer style="flex-shrink: 0; margin-top: 5px; padding-top: 10px; border-top: 1px solid var(--color-border-light-1); display: flex; justify-content: flex-end;">
        <button type="submit" style="width: auto; padding: 4px 12px; font-size: 0.9em; cursor: pointer;">
            <i class="fas fa-save"></i> Save Preferences
        </button>
    </footer>
</div>